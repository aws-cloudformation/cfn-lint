{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/Name",
  "/properties/KmsKeyId"
 ],
 "definitions": {
  "AvailabilitySlo": {
   "additionalProperties": false,
   "properties": {
    "Target": {
     "description": "Availability target percentage.",
     "maximum": 100,
     "minimum": 0,
     "type": "number"
    }
   },
   "type": "object"
  },
  "DataRecoveryTargets": {
   "additionalProperties": false,
   "properties": {
    "TimeBetweenBackupsInMinutes": {
     "description": "Time between backups in minutes.",
     "minimum": 0,
     "type": "integer"
    }
   },
   "type": "object"
  },
  "MultiAzTargets": {
   "additionalProperties": false,
   "properties": {
    "DisasterRecoveryApproach": {
     "description": "Multi-AZ disaster recovery approach.",
     "enum": [
      "ACTIVE_ACTIVE",
      "HOT_STANDBY",
      "WARM_STANDBY",
      "PILOT_LIGHT",
      "BACKUP_AND_RESTORE"
     ],
     "type": "string"
    },
    "RpoInMinutes": {
     "description": "Recovery Point Objective in minutes.",
     "maximum": 2147483647,
     "minimum": 0,
     "type": "integer"
    },
    "RtoInMinutes": {
     "description": "Recovery Time Objective in minutes.",
     "maximum": 2147483647,
     "minimum": 0,
     "type": "integer"
    }
   },
   "type": "object"
  },
  "MultiRegionTargets": {
   "additionalProperties": false,
   "properties": {
    "DisasterRecoveryApproach": {
     "description": "Multi-Region disaster recovery approach.",
     "enum": [
      "ACTIVE_ACTIVE",
      "HOT_STANDBY",
      "WARM_STANDBY",
      "PILOT_LIGHT",
      "BACKUP_AND_RESTORE"
     ],
     "type": "string"
    },
    "RpoInMinutes": {
     "description": "Recovery Point Objective in minutes.",
     "maximum": 2147483647,
     "minimum": 0,
     "type": "integer"
    },
    "RtoInMinutes": {
     "description": "Recovery Time Objective in minutes.",
     "maximum": 2147483647,
     "minimum": 0,
     "type": "integer"
    }
   },
   "type": "object"
  },
  "Tag": {
   "additionalProperties": false,
   "properties": {
    "Key": {
     "description": "The tag key.",
     "maxLength": 128,
     "minLength": 1,
     "type": "string"
    },
    "Value": {
     "description": "The tag value.",
     "maxLength": 256,
     "minLength": 0,
     "type": "string"
    }
   },
   "required": [
    "Key",
    "Value"
   ],
   "type": "object"
  }
 },
 "description": "Creates a resilience policy that defines availability and disaster recovery requirements.",
 "handlers": {
  "create": {
   "permissions": [
    "resiliencehub:CreatePolicy",
    "resiliencehub:GetPolicy",
    "resiliencehub:TagResource",
    "resiliencehub:ListTagsForResource",
    "kms:DescribeKey",
    "kms:GenerateDataKey",
    "kms:Decrypt",
    "kms:Encrypt",
    "kms:CreateGrant",
    "kms:RetireGrant"
   ]
  },
  "delete": {
   "permissions": [
    "resiliencehub:DeletePolicy",
    "resiliencehub:GetPolicy",
    "kms:Decrypt",
    "kms:DescribeKey",
    "kms:RetireGrant",
    "kms:GenerateDataKey",
    "kms:Encrypt",
    "kms:CreateGrant"
   ]
  },
  "list": {
   "permissions": [
    "resiliencehub:ListPolicies"
   ]
  },
  "read": {
   "permissions": [
    "resiliencehub:GetPolicy",
    "resiliencehub:ListTagsForResource",
    "kms:Decrypt",
    "kms:DescribeKey"
   ]
  },
  "update": {
   "permissions": [
    "resiliencehub:UpdatePolicy",
    "resiliencehub:GetPolicy",
    "resiliencehub:TagResource",
    "resiliencehub:UntagResource",
    "resiliencehub:ListTagsForResource",
    "kms:Decrypt",
    "kms:DescribeKey",
    "kms:GenerateDataKey",
    "kms:Encrypt",
    "kms:CreateGrant",
    "kms:RetireGrant"
   ]
  }
 },
 "primaryIdentifier": [
  "/properties/PolicyArn"
 ],
 "properties": {
  "AssociatedServiceCount": {
   "description": "The number of services associated with this policy.",
   "type": "integer"
  },
  "AvailabilitySlo": {
   "$ref": "#/definitions/AvailabilitySlo"
  },
  "CreatedAt": {
   "description": "The timestamp when the policy was created.",
   "format": "date-time",
   "type": "string"
  },
  "DataRecovery": {
   "$ref": "#/definitions/DataRecoveryTargets"
  },
  "Description": {
   "description": "The description of the policy.",
   "maxLength": 615,
   "type": "string"
  },
  "KmsKeyId": {
   "anyOf": [
    {
     "format": "AWS::KMS::Key.Arn"
    },
    {
     "format": "AWS::KMS::Key.Id"
    },
    {
     "format": "AWS::KMS::Alias.AliasName"
    }
   ],
   "description": "The KMS key ID for encrypting policy data.",
   "maxLength": 2048,
   "minLength": 1,
   "pattern": "^((arn:aws(-[^:]+)?:kms:[a-zA-Z0-9-]*:[0-9]{12}:((key/[a-zA-Z0-9-]{36})|(alias/[a-zA-Z0-9-_/]+)))|([a-zA-Z0-9-]{36})|(alias/[a-zA-Z0-9-_/]+))$",
   "type": "string"
  },
  "MultiAz": {
   "$ref": "#/definitions/MultiAzTargets"
  },
  "MultiRegion": {
   "$ref": "#/definitions/MultiRegionTargets"
  },
  "Name": {
   "description": "The name of the policy.",
   "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-]{1,59}$",
   "type": "string"
  },
  "PolicyArn": {
   "description": "The ARN of the policy.",
   "pattern": "^arn:(aws|aws-cn|aws-iso|aws-iso-[a-z]{1}|aws-us-gov):[A-Za-z0-9][A-Za-z0-9_/.-]{0,62}:([a-z]{2}-((iso[a-z]{0,1}-)|(gov-)){0,1}[a-z]+-[0-9]):[0-9]{12}:[A-Za-z0-9/][A-Za-z0-9:_/+.-]{0,1023}$",
   "type": "string"
  },
  "Tags": {
   "description": "Tags assigned to the policy.",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "type": "array"
  },
  "UpdatedAt": {
   "description": "The timestamp when the policy was last updated.",
   "format": "date-time",
   "type": "string"
  }
 },
 "readOnlyProperties": [
  "/properties/PolicyArn",
  "/properties/CreatedAt",
  "/properties/UpdatedAt",
  "/properties/AssociatedServiceCount"
 ],
 "required": [
  "Name"
 ],
 "tagging": {
  "cloudFormationSystemTags": true,
  "permissions": [
   "resiliencehub:TagResource",
   "resiliencehub:UntagResource",
   "resiliencehub:ListTagsForResource"
  ],
  "tagOnCreate": true,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": true,
  "taggable": true
 },
 "typeName": "AWS::ResilienceHubV2::Policy",
 "writeOnlyProperties": [
  "/properties/KmsKeyId"
 ]
}
