    "CodeInterpreterId",
    "CodeInterpreterArn",
    "Status",
    "CreatedAt"
   ],
   "type": "object"
  },
  "Description": {
   "description": "Description of the code interpreter.",
   "type": "string"
  },
  "RoleArn": {
   "description": "The ARN of the IAM role.",
   "format": "AWS::IAM::Role.Arn",
   "pattern": "^arn:(aws(?:-cn|-us-gov|-iso(?:-[bef])?)?):iam::[0-9]{12}:role/.+$",
   "type": "string"
  },
  "SandboxName": {
   "description": "The name of the sandbox.",
   "type": "string"
  },
  "SecurityGroupId": {
   "description": "Security group id",
   "format": "AWS::EC2::SecurityGroup.Id",
   "pattern": "^sg-[0-9a-zA-Z]{8,17}$",
   "type": "string"
  },
  "SecurityGroups": {
   "description": "Security groups for VPC",
   "format": "AWS::EC2::SecurityGroup.Ids",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/SecurityGroupId"
   },
   "maxItems": 16,
   "minItems": 1,
   "type": "array"
  },
  "SubnetId": {
   "description": "Subnet id",
   "format": "AWS::EC2::Subnet.Id",
   "pattern": "^subnet-[0-9a-zA-Z]{8,17}$",
   "type": "string"
  },
  "Subnets": {
   "description": "Subnets for VPC",
   "format": "AWS::EC2::Subnet.Ids",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/SubnetId"
   },
   "maxItems": 16,
   "minItems": 1,
   "type": "array"
  },
  "TagsMap": {
   "additionalProperties": false,
   "description": "A map of tag keys and values",
   "patternProperties": {
    "^[a-zA-Z0-9\\s._:/=+@-]*$": {
     "description": "Value of a tag",
     "maxLength": 256,
     "minLength": 0,
     "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$",
     "type": "string"
    }
   },
   "type": "object"
  },
  "VpcConfig": {
   "additionalProperties": false,
   "description": "Network mode configuration for VPC",
   "properties": {
    "SecurityGroups": {
     "$ref": "#/definitions/SecurityGroups"
    },
    "Subnets": {
     "$ref": "#/definitions/Subnets"
    }
   },
   "required": [
    "SecurityGroups",
    "Subnets"
   ],
   "type": "object"
  }
 },
