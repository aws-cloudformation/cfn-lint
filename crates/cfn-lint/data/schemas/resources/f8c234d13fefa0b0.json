   "enum": [
    "PUBLIC",
    "SANDBOX",
    "VPC"
   ],
   "type": "string"
  },
  "CodeInterpreterStatus": {
   "description": "Status of Code interpreter",
   "enum": [
    "CREATING",
    "CREATE_FAILED",
    "READY",
    "DELETING",
    "DELETE_FAILED",
    "DELETED"
   ],
   "type": "string"
  },
  "CodeInterpreterSummaries": {
