{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/ServiceType",
  "/properties/ServiceDetails/Dynatrace",
  "/properties/ServiceDetails/MCPServer",
  "/properties/ServiceDetails/MCPServerSplunk",
  "/properties/ServiceDetails/MCPServerNewRelic",
  "/properties/ServiceDetails/ServiceNow",
  "/properties/ServiceDetails/PagerDuty",
