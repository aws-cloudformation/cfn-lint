     "type": "string"
    },
    "Service": {
     "description": "AWS service name for SigV4 signing",
     "type": "string"
    }
   },
   "required": [
    "Name",
    "Endpoint",
    "Region",
    "Service",
    "RoleArn"
   ],
   "type": "object"
  },
  "RegisteredNewRelicDetails": {
   "additionalProperties": false,
   "description": "New Relic service details returned after registration",
   "properties": {
