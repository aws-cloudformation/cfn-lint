      }
     },
     "required": [
      "MCPServerNewRelic"
     ]
    },
    {
     "additionalProperties": false,
     "properties": {
      "Dynatrace": {
       "$ref": "#/definitions/RegisteredDynatraceDetails"
      }
     },
     "required": [
      "Dynatrace"
     ]
    },
    {
     "additionalProperties": false,
     "properties": {
      "ServiceNow": {
       "$ref": "#/definitions/RegisteredServiceNowDetails"
      }
     },
