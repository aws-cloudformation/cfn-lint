  "NewRelicApiKeyConfig": {
   "additionalProperties": false,
   "description": "New Relic API key configuration",
   "properties": {
    "AccountId": {
     "description": "New Relic Account ID",
     "pattern": "^[0-9]+$",
     "type": "string"
    },
    "AlertPolicyIds": {
     "description": "List of alert policy IDs",
     "items": {
      "pattern": "^[0-9]+$",
      "type": "string"
     },
     "type": "array"
    },
    "ApiKey": {
     "description": "New Relic User API Key",
     "pattern": "^NRAK-[A-Z0-9]+$",
     "type": "string"
    },
    "ApplicationIds": {
     "description": "List of monitored APM application IDs",
     "items": {
      "pattern": "^[0-9]+$",
      "type": "string"
     },
     "type": "array"
    },
    "EntityGuids": {
     "description": "List of globally unique IDs for New Relic resources",
     "items": {
      "pattern": "^[a-zA-Z0-9_.-]+$",
      "type": "string"
     },
     "type": "array"
    },
    "Region": {
     "description": "New Relic region",
     "enum": [
      "US",
      "EU"
     ],
     "type": "string"
    }
   },
   "required": [
    "ApiKey",
    "AccountId",
    "Region"
   ],
   "type": "object"
  },
  "NewRelicAuthorizationConfig": {
