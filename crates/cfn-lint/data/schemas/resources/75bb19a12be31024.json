      "PagerDuty"
     ]
    },
    {
     "additionalProperties": false,
     "properties": {
      "AzureIdentity": {
       "$ref": "#/definitions/RegisteredAzureIdentityDetails"
      }
     },
     "required": [
      "AzureIdentity"
     ]
    },
    {
     "additionalProperties": false,
     "properties": {
      "MCPServerSigV4": {
       "$ref": "#/definitions/RegisteredMCPServerSigV4Details"
      }
     },
     "required": [
      "MCPServerSigV4"
     ]
    },
    {
     "additionalProperties": false,
     "properties": {
      "MCPServerGrafana": {
       "$ref": "#/definitions/RegisteredMCPServerGrafanaDetails"
      }
     },
     "required": [
      "MCPServerGrafana"
     ]
    }
   ],
   "type": "object"
  },
  "ApiKeyDetails": {
   "additionalProperties": false,
   "description": "API key authentication details",
   "properties": {
    "ApiKeyHeader": {
     "description": "HTTP header name to send the API key",
     "pattern": "^[a-zA-Z0-9-]+$",
     "type": "string"
    },
    "ApiKeyName": {
     "description": "User friendly API key name",
     "pattern": "^[a-zA-Z0-9_\\s-]+$",
     "type": "string"
    },
    "ApiKeyValue": {
     "description": "API key value",
     "pattern": "^[!-~]([ \\t]*[!-~])*$",
     "type": "string"
    }
   },
   "required": [
    "ApiKeyName",
    "ApiKeyValue",
    "ApiKeyHeader"
   ],
   "type": "object"
  },
  "AzureIdentityServiceDetails": {
   "additionalProperties": false,
   "description": "Azure Identity service configuration for federated identity",
   "properties": {
    "ClientId": {
     "description": "Azure AD application client ID",
     "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
     "type": "string"
    },
    "TenantId": {
     "description": "Azure AD tenant ID",
     "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$",
     "type": "string"
    },
    "WebIdentityRoleArn": {
     "description": "ARN of the IAM role for web identity token exchange",
     "format": "AWS::IAM::Role.Arn",
     "pattern": "^arn:aws[a-zA-Z-]*:iam::[0-9]{12}:role/.+$",
     "type": "string"
    },
    "WebIdentityTokenAudiences": {
     "description": "List of audiences for the web identity token",
     "items": {
      "type": "string"
     },
     "minItems": 1,
     "type": "array"
    }
   },
   "required": [
    "TenantId",
    "ClientId",
    "WebIdentityRoleArn",
    "WebIdentityTokenAudiences"
   ],
   "type": "object"
  },
  "BearerTokenDetails": {
   "additionalProperties": false,
   "description": "Bearer token authentication details",
   "properties": {
    "AuthorizationHeader": {
     "default": "Authorization",
     "description": "HTTP header name to send the bearer token",
     "pattern": "^[a-zA-Z0-9-]+$",
     "type": "string"
    },
    "TokenName": {
     "description": "User friendly bearer token name",
     "pattern": "^[a-zA-Z0-9_\\s-]+$",
     "type": "string"
    },
    "TokenValue": {
     "description": "Bearer token value",
     "pattern": "^[\\S]+$",
     "type": "string"
    }
   },
   "required": [
    "TokenName",
    "TokenValue"
   ],
   "type": "object"
  },
  "DynatraceAuthorizationConfig": {
   "additionalProperties": false,
   "description": "Dynatrace OAuth authorization configuration",
   "properties": {
    "OAuthClientCredentials": {
     "$ref": "#/definitions/OAuthClientDetails"
    }
   },
   "type": "object"
  },
  "DynatraceServiceDetails": {
   "additionalProperties": false,
   "description": "Dynatrace service configuration",
   "properties": {
    "AccountUrn": {
     "description": "Dynatrace resource account URN",
     "type": "string"
    },
    "AuthorizationConfig": {
     "$ref": "#/definitions/DynatraceAuthorizationConfig"
    }
   },
   "required": [
    "AccountUrn"
   ],
   "type": "object"
  },
  "GitLabDetails": {
   "additionalProperties": false,
   "description": "GitLab service configuration",
   "properties": {
    "GroupId": {
     "description": "Optional GitLab group ID for group-level access tokens",
     "type": "string"
    },
    "TargetUrl": {
     "description": "GitLab instance URL",
     "pattern": "^https://[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?(?::[0-9]{1,5})?/?$",
     "type": "string"
    },
    "TokenType": {
     "description": "Type of GitLab access token",
     "enum": [
      "personal",
      "group"
     ],
     "type": "string"
    },
    "TokenValue": {
     "description": "GitLab access token value",
     "pattern": "^glpat-[a-zA-Z0-9._-]+$",
     "type": "string"
    }
   },
   "required": [
    "TargetUrl",
    "TokenType",
    "TokenValue"
   ],
   "type": "object"
  },
  "MCPServerAuthorizationConfig": {
   "description": "MCP server authorization configuration",
   "oneOf": [
    {
     "additionalProperties": false,
     "properties": {
      "OAuthClientCredentials": {
       "$ref": "#/definitions/MCPServerOAuthClientCredentialsConfig"
      }
     },
     "required": [
      "OAuthClientCredentials"
     ]
    },
    {
     "additionalProperties": false,
     "properties": {
      "ApiKey": {
       "$ref": "#/definitions/ApiKeyDetails"
      }
     },
     "required": [
      "ApiKey"
     ]
    }
   ],
   "type": "object"
  },
  "MCPServerDetails": {
   "additionalProperties": false,
   "description": "MCP server configuration",
   "properties": {
    "AuthorizationConfig": {
     "$ref": "#/definitions/MCPServerAuthorizationConfig"
    },
    "Description": {
     "description": "Optional description for the MCP server",
     "maxLength": 500,
     "type": "string"
    },
    "Endpoint": {
     "description": "MCP server endpoint URL",
     "pattern": "^https://[a-zA-Z0-9.-]+(?::[0-9]+)?(?:/.*)?$",
     "type": "string"
    },
    "Name": {
     "description": "MCP server name",
     "pattern": "^[a-zA-Z0-9_-]+$",
     "type": "string"
    }
   },
   "required": [
    "Name",
    "Endpoint",
    "AuthorizationConfig"
   ],
   "type": "object"
  },
  "MCPServerGrafanaAuthorizationConfig": {
   "description": "Grafana MCP server authorization configuration",
   "oneOf": [
    {
     "additionalProperties": false,
     "properties": {
      "BearerToken": {
       "$ref": "#/definitions/BearerTokenDetails"
      }
     },
     "required": [
      "BearerToken"
     ]
    }
   ],
   "type": "object"
  },
  "MCPServerGrafanaDetails": {
   "additionalProperties": false,
   "description": "Grafana MCP server configuration",
   "properties": {
    "AuthorizationConfig": {
     "$ref": "#/definitions/MCPServerGrafanaAuthorizationConfig"
    },
    "Description": {
     "description": "Optional description for the MCP server",
     "maxLength": 500,
     "type": "string"
    },
    "Endpoint": {
     "description": "MCP server endpoint URL",
     "pattern": "^https://[a-zA-Z0-9.-]+(?::[0-9]+)?(?:/.*)?$",
     "type": "string"
    },
    "Name": {
     "description": "MCP server name",
     "pattern": "^[a-zA-Z0-9_-]+$",
