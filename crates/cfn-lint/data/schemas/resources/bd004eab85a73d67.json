{
 "additionalIdentifiers": [
  [
   "/properties/Name"
  ]
 ],
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/Name",
  "/properties/Description",
  "/properties/ExportConfig"
 ],
 "definitions": {
  "WorkflowExportConfig": {
   "additionalProperties": false,
   "description": "Configuration settings for exporting workflow execution data and logs to Amazon S3.",
   "properties": {
    "S3BucketName": {
     "description": "The name of the Amazon S3 bucket for exporting workflow data.",
     "format": "AWS::S3::Bucket.Name",
     "maxLength": 63,
     "minLength": 3,
     "pattern": "^[a-z0-9][a-z0-9.-]*[a-z0-9]$",
     "type": "string"
    },
    "S3KeyPrefix": {
     "description": "An optional prefix for Amazon S3 object keys to organize exported data.",
     "maxLength": 100,
     "minLength": 1,
     "pattern": "^[a-zA-Z0-9!\\-_.*'()]+(?:/[a-zA-Z0-9!\\-_.*'()]+)*$",
     "type": "string"
    }
   },
   "required": [
    "S3BucketName"
   ],
   "type": "object"
  }
 },
 "description": "Definition of AWS::NovaAct::WorkflowDefinition Resource Type",
 "handlers": {
  "create": {
   "permissions": [
    "nova-act:CreateWorkflowDefinition",
    "nova-act:GetWorkflowDefinition",
    "iam:CreateServiceLinkedRole",
    "s3:ListBucket",
    "s3:GetBucketLocation",
    "s3:GetBucketAcl",
    "s3:PutObject"
   ]
  },
  "delete": {
   "permissions": [
    "nova-act:DeleteWorkflowDefinition",
    "nova-act:GetWorkflowDefinition"
   ]
  },
  "list": {
   "permissions": [
    "nova-act:ListWorkflowDefinitions"
   ]
  },
  "read": {
   "permissions": [
    "nova-act:GetWorkflowDefinition"
   ]
  }
 },
 "primaryIdentifier": [
  "/properties/Arn"
 ],
 "properties": {
  "Arn": {
   "description": "The Amazon Resource Name (ARN) of the workflow definition.",
   "pattern": "^arn:(aws|aws-cn|aws-us-gov):nova-act:[a-z0-9-]+:[0-9]{12}:workflow-definition/[a-zA-Z0-9_-]{1,40}$",
   "type": "string"
  },
  "CreatedAt": {
   "description": "The timestamp when the workflow definition was created.",
   "format": "date-time",
   "type": "string"
  },
  "Description": {
   "description": "An optional description of the workflow definition's purpose and functionality.",
   "maxLength": 4000,
   "minLength": 1,
   "type": "string"
  },
  "ExportConfig": {
   "$ref": "#/definitions/WorkflowExportConfig"
  },
  "Name": {
   "description": "The name of the workflow definition. Must be unique within your account and region.",
   "maxLength": 40,
   "minLength": 1,
   "pattern": "^[a-zA-Z0-9_-]{1,40}$",
   "type": "string"
  },
  "Status": {
   "description": "The current status of the workflow definition.",
   "enum": [
    "ACTIVE",
    "DELETING"
   ],
   "type": "string"
  }
 },
 "readOnlyProperties": [
  "/properties/Arn",
  "/properties/CreatedAt",
  "/properties/Status"
 ],
 "required": [
  "Name"
 ],
 "tagging": {
  "taggable": false
 },
 "typeName": "AWS::NovaAct::WorkflowDefinition"
}
