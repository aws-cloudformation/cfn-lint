    "$ref": "#/definitions/AssetId"
   },
   "type": "array",
   "uniqueItems": true
  },
  "PortalId": {
   "description": "The ID of the portal in which to create the project.",
   "maxLength": 36,
   "minLength": 36,
   "pattern": "^(?!00000000-0000-0000-0000-000000000000)[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
   "type": "string"
  },
  "ProjectArn": {
   "description": "The ARN of the project.",
   "type": "string"
  },
  "ProjectDescription": {
   "description": "A description for the project.",
   "maxLength": 2048,
   "minLength": 1,
   "pattern": "^[^\\u0000-\\u001F\\u007F]+$",
   "type": "string"
  },
  "ProjectId": {
   "description": "The ID of the project.",
   "type": "string"
  },
  "ProjectName": {
   "description": "A friendly name for the project.",
   "maxLength": 256,
   "minLength": 1,
   "pattern": "^[^\\u0000-\\u001F\\u007F]+$",
   "type": "string"
  },
  "Tags": {
   "description": "A list of key-value pairs that contain metadata for the project.",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "type": "array",
   "uniqueItems": false
  }
 },
 "readOnlyProperties": [
  "/properties/ProjectId",
