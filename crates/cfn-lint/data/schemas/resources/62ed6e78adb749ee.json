{
 "additionalIdentifiers": [
  [
   "/properties/VirtualClusterId",
   "/properties/Id"
  ]
 ],
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/Name",
  "/properties/VirtualClusterId",
  "/properties/Type",
  "/properties/ReleaseLabel",
  "/properties/ExecutionRoleArn",
  "/properties/ConfigurationOverrides",
  "/properties/SessionIdleTimeoutInMinutes"
 ],
 "definitions": {
  "Certificate": {
   "additionalProperties": false,
   "properties": {
    "CertificateArn": {
     "type": "string"
    },
    "CertificateData": {
     "type": "string"
    }
   },
   "type": "object"
  },
  "CloudWatchMonitoringConfiguration": {
   "additionalProperties": false,
   "properties": {
    "LogGroupName": {
     "format": "AWS::Logs::LogGroup.Name",
     "maxLength": 512,
     "minLength": 1,
     "pattern": "^[\\.\\-_/#A-Za-z0-9]+$",
     "type": "string"
    },
    "LogStreamNamePrefix": {
     "maxLength": 256,
     "minLength": 1,
     "pattern": "\\S",
     "type": "string"
    }
   },
   "required": [
    "LogGroupName"
   ],
   "type": "object"
  },
  "ConfigurationOverrides": {
   "additionalProperties": false,
   "properties": {
    "ApplicationConfiguration": {
     "items": {
      "$ref": "#/definitions/EMREKSConfiguration"
     },
     "maxItems": 100,
     "minItems": 0,
     "type": "array"
    },
    "MonitoringConfiguration": {
     "$ref": "#/definitions/MonitoringConfiguration"
    }
   },
   "type": "object"
  },
  "ContainerLogRotationConfiguration": {
   "additionalProperties": false,
   "properties": {
    "MaxFilesToKeep": {
     "maximum": 50,
     "minimum": 1,
     "type": "integer"
    },
    "RotationSize": {
     "maxLength": 12,
     "minLength": 3,
     "pattern": "^\\d+(\\.\\d+)?[KMG][Bb]?$",
     "type": "string"
    }
   },
   "required": [
    "RotationSize",
    "MaxFilesToKeep"
   ],
   "type": "object"
  },
  "EMREKSConfiguration": {
   "additionalProperties": false,
   "properties": {
    "Classification": {
     "maxLength": 1024,
     "minLength": 1,
     "pattern": "\\S",
     "type": "string"
    },
    "Configurations": {
     "items": {
      "$ref": "#/definitions/EMREKSConfiguration"
     },
     "maxItems": 100,
     "minItems": 0,
     "type": "array"
    },
    "Properties": {
     "additionalProperties": false,
     "patternProperties": {
      ".*": {
       "type": "string"
      }
     },
     "type": "object"
    }
   },
   "required": [
    "Classification"
   ],
   "type": "object"
  },
  "MonitoringConfiguration": {
   "additionalProperties": false,
   "properties": {
    "CloudWatchMonitoringConfiguration": {
     "$ref": "#/definitions/CloudWatchMonitoringConfiguration"
    },
    "ContainerLogRotationConfiguration": {
     "$ref": "#/definitions/ContainerLogRotationConfiguration"
    },
    "PersistentAppUI": {
     "enum": [
      "ENABLED",
      "DISABLED"
     ],
     "type": "string"
    },
    "S3MonitoringConfiguration": {
     "$ref": "#/definitions/S3MonitoringConfiguration"
    }
   },
   "type": "object"
  },
  "S3MonitoringConfiguration": {
   "additionalProperties": false,
   "properties": {
    "LogUri": {
     "maxLength": 10280,
     "minLength": 1,
     "pattern": "^[\\u0020-\\uD7FF\\uE000-\\uFFFD\\uD800\\uDBFF-\\uDC00\\uDFFF\\r\\n\\t]*$",
     "type": "string"
    }
   },
   "required": [
    "LogUri"
   ],
   "type": "object"
  },
  "Tag": {
   "additionalProperties": false,
   "properties": {
    "Key": {
     "description": "A user-defined key, which is the minimum required information for a valid tag.",
     "maxLength": 128,
     "minLength": 1,
     "type": "string"
    },
    "Value": {
     "description": "A user-defined value, which is optional in a tag.",
     "maxLength": 256,
     "minLength": 0,
     "type": "string"
    }
   },
   "required": [
    "Key",
    "Value"
   ],
   "type": "object"
  }
 },
 "description": "Resource Schema of AWS::EMRContainers::Endpoint Type",
 "handlers": {
  "create": {
   "permissions": [
    "emr-containers:CreateManagedEndpoint",
    "emr-containers:DescribeManagedEndpoint",
    "emr-containers:TagResource",
    "iam:PassRole",
    "ec2:CreateSecurityGroup",
    "ec2:DeleteSecurityGroup",
    "ec2:AuthorizeSecurityGroupEgress",
    "ec2:AuthorizeSecurityGroupIngress",
    "ec2:RevokeSecurityGroupEgress",
    "ec2:RevokeSecurityGroupIngress"
   ]
  },
  "delete": {
   "permissions": [
    "emr-containers:DeleteManagedEndpoint",
    "emr-containers:DescribeManagedEndpoint",
    "ec2:DeleteSecurityGroup",
    "ec2:DescribeSecurityGroup",
    "ec2:DescribeNetworkInterfaces",
    "ec2:DeleteNetworkInterface",
    "ec2:AuthorizeSecurityGroupEgress",
    "ec2:AuthorizeSecurityGroupIngress",
    "ec2:RevokeSecurityGroupEgress",
    "ec2:RevokeSecurityGroupIngress"
   ]
  },
  "list": {
   "permissions": [
    "emr-containers:ListManagedEndpoints"
   ]
  },
  "read": {
   "permissions": [
    "emr-containers:DescribeManagedEndpoint",
    "emr-containers:ListTagsForResource"
   ]
  },
  "update": {
   "permissions": [
    "emr-containers:DescribeManagedEndpoint",
    "emr-containers:ListTagsForResource",
    "emr-containers:TagResource",
    "emr-containers:UntagResource"
   ]
  }
 },
 "primaryIdentifier": [
  "/properties/Arn"
 ],
 "properties": {
  "Arn": {
   "description": "The ARN of the managed endpoint.",
   "type": "string"
  },
  "AuthProxyUrl": {
   "description": "The auth proxy URL for Spark Connect connections.",
   "type": "string"
  },
  "CertificateAuthority": {
   "$ref": "#/definitions/Certificate",
   "description": "The certificate authority for the managed endpoint."
  },
  "ConfigurationOverrides": {
   "$ref": "#/definitions/ConfigurationOverrides",
   "description": "The configuration overrides for the managed endpoint."
  },
  "CreatedAt": {
   "description": "The date and time when the managed endpoint was created.",
   "type": "string"
  },
  "ExecutionRoleArn": {
   "description": "The execution role ARN for the managed endpoint.",
   "format": "AWS::IAM::Role.Arn",
   "maxLength": 2048,
   "minLength": 20,
   "pattern": "^arn:(aws[a-zA-Z0-9-]*):iam::(\\d{12})?:(role((\\u002F)|(\\u002F[\\u0021-\\u007F]+\\u002F))[\\w+=,.@-]+)$",
   "type": "string"
  },
  "FailureReason": {
   "description": "The reason for a failed managed endpoint.",
   "type": "string"
  },
  "Id": {
   "description": "The ID of the managed endpoint.",
   "type": "string"
  },
  "Name": {
   "description": "The name of the managed endpoint.",
   "maxLength": 64,
   "minLength": 1,
   "pattern": "[0-9A-Za-z][A-Za-z0-9\\-_]*",
   "type": "string"
  },
  "ReleaseLabel": {
   "description": "The Amazon EMR release label.",
   "maxLength": 64,
   "minLength": 1,
   "pattern": "[A-Za-z0-9._/-]+",
   "type": "string"
  },
  "SecurityGroup": {
   "description": "The security group associated with the managed endpoint.",
   "format": "AWS::EC2::SecurityGroup.Id",
   "type": "string"
  },
  "ServerUrl": {
   "description": "The server URL of the managed endpoint.",
   "type": "string"
  },
  "SessionIdleTimeoutInMinutes": {
   "description": "The idle timeout in minutes for sessions on the managed endpoint.",
   "maximum": 1440,
   "minimum": 1,
   "type": "integer"
  },
  "State": {
   "description": "The state of the managed endpoint.",
   "type": "string"
  },
  "StateDetails": {
   "description": "Additional details about the state of the managed endpoint.",
   "type": "string"
  },
  "Tags": {
   "description": "An array of key-value pairs to apply to this managed endpoint.",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "type": "array",
   "uniqueItems": true
  },
  "Type": {
   "description": "The type of the managed endpoint.",
   "maxLength": 64,
   "minLength": 1,
   "pattern": "\\S",
   "type": "string"
  },
  "VirtualClusterId": {
   "description": "The ID of the virtual cluster for which the managed endpoint is created.",
   "maxLength": 64,
   "minLength": 1,
   "pattern": "^[0-9a-z]+$",
   "type": "string"
  }
 },
 "readOnlyProperties": [
  "/properties/Arn",
  "/properties/Id",
  "/properties/ServerUrl",
  "/properties/State",
  "/properties/StateDetails",
  "/properties/FailureReason",
  "/properties/CreatedAt",
  "/properties/SecurityGroup",
  "/properties/CertificateAuthority",
  "/properties/AuthProxyUrl"
 ],
 "required": [
  "VirtualClusterId",
  "Type",
  "ReleaseLabel",
  "ExecutionRoleArn"
 ],
 "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
 "tagging": {
  "cloudFormationSystemTags": true,
  "permissions": [
   "emr-containers:TagResource",
   "emr-containers:UntagResource",
   "emr-containers:ListTagsForResource"
  ],
  "tagOnCreate": true,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": true,
  "taggable": true
 },
 "typeName": "AWS::EMRContainers::Endpoint",
 "writeOnlyProperties": [
  "/properties/SessionIdleTimeoutInMinutes"
 ]
}
