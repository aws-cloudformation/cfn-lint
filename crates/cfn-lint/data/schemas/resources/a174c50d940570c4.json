 ],
 "definitions": {
  "ExpirationDataRule": {
   "additionalProperties": false,
   "properties": {
    "DaysAfterLastAccess": {
     "maximum": 365,
     "minimum": 1,
     "type": "integer"
    }
   },
   "required": [
    "DaysAfterLastAccess"
   ],
   "type": "object"
  },
  "ImportDataRule": {
   "additionalProperties": false,
   "properties": {
    "Prefix": {
     "maxLength": 1024,
     "minLength": 0,
     "pattern": "^(|.*/)$",
     "type": "string"
    },
    "SizeLessThan": {
     "format": "int64",
     "maximum": 52673613135872,
     "minimum": 0,
     "type": "integer"
    },
    "Trigger": {
     "enum": [
      "ON_DIRECTORY_FIRST_ACCESS",
      "ON_FILE_ACCESS"
     ],
     "type": "string"
    }
   },
   "required": [
    "Prefix",
    "Trigger",
    "SizeLessThan"
   ],
   "type": "object"
  },
  "SynchronizationConfiguration": {
   "additionalProperties": false,
   "properties": {
    "ExpirationDataRules": {
     "items": {
      "$ref": "#/definitions/ExpirationDataRule"
     },
     "maxItems": 1,
     "minItems": 1,
     "type": "array"
    },
    "ImportDataRules": {
     "items": {
      "$ref": "#/definitions/ImportDataRule"
     },
     "maxItems": 10,
     "minItems": 1,
     "type": "array"
    },
    "LatestVersionNumber": {
     "type": "integer"
    }
   },
   "required": [
    "ImportDataRules",
    "ExpirationDataRules"
   ],
   "type": "object"
  },
  "Tag": {
   "additionalProperties": false,
   "properties": {
    "Key": {
     "maxLength": 128,
     "minLength": 1,
     "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]+)$",
     "type": "string"
    },
    "Value": {
     "maxLength": 256,
     "pattern": "^([\\p{L}\\p{Z}\\p{N}_.:/=+\\-@]*)$",
     "type": "string"
    }
   },
   "required": [
    "Value",
    "Key"
   ],
   "type": "object"
  }
 },
