   "type": "boolean"
  },
  "Bucket": {
   "pattern": "^(arn:aws[a-zA-Z0-9-]*:s3:::.+)$",
   "type": "string"
  },
  "ClientToken": {
   "maxLength": 64,
   "minLength": 1,
   "pattern": "^(.+)$",
   "type": "string"
  },
  "CreationTime": {
   "format": "date-time",
   "type": "string"
  },
  "FileSystemArn": {
   "pattern": "^(arn:aws[-a-z]*:s3files:[0-9a-z-:]+:file-system/fs-[0-9a-f]{17,40})$",
   "type": "string"
  },
  "FileSystemId": {
   "maxLength": 128,
   "pattern": "^(arn:aws[-a-z]*:s3files:[0-9a-z-:]+:file-system/fs-[0-9a-f]{17,40}|fs-[0-9a-f]{17,40})$",
   "type": "string"
  },
  "KmsKeyId": {
   "anyOf": [
    {
     "format": "AWS::KMS::Key.Arn"
    },
    {
     "format": "AWS::KMS::Key.Id"
    },
    {
     "format": "AWS::KMS::Alias.AliasName"
    }
   ],
   "maxLength": 2048,
   "pattern": "^([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}|mrk-[0-9a-f]{32}|alias/[a-zA-Z0-9/_-]+|(arn:aws[-a-z]*:kms:[a-z0-9-]+:\\d{12}:((key/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})|(key/mrk-[0-9a-f]{32})|(alias/[a-zA-Z0-9/_-]+))))$",
   "type": "string"
  },
  "OwnerId": {
   "type": "string"
  },
  "Prefix": {
   "maxLength": 1024,
   "pattern": "^(|.*/)$",
   "type": "string"
  },
  "RoleArn": {
   "format": "AWS::IAM::Role.Arn",
   "maxLength": 2048,
   "pattern": "^arn:(aws[a-zA-Z-]*)?:iam::\\d{12}:role/?[a-zA-Z_0-9+=,.@\\-_/]+$",
   "type": "string"
  },
  "Status": {
   "enum": [
    "creating",
    "available",
    "updating",
    "deleting",
    "deleted",
    "error"
   ],
   "type": "string"
  },
  "StatusMessage": {
   "type": "string"
  },
  "SynchronizationConfiguration": {
   "$ref": "#/definitions/SynchronizationConfiguration"
  },
  "Tags": {
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "minItems": 1,
   "type": "array",
   "uniqueItems": true
  }
 },
 "propertyTransform": {
