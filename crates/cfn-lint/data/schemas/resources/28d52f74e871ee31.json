 "description": "Resource Type definition for AWS::SageMaker::Algorithm",
 "handlers": {
  "create": {
   "permissions": [
    "sagemaker:CreateAlgorithm",
    "sagemaker:DescribeAlgorithm",
    "sagemaker:AddTags"
   ]
  },
  "delete": {
   "permissions": [
    "sagemaker:DeleteAlgorithm",
    "sagemaker:DescribeAlgorithm"
   ]
  },
  "list": {
   "permissions": [
    "sagemaker:ListAlgorithms"
   ]
  },
  "read": {
   "permissions": [
    "sagemaker:DescribeAlgorithm",
    "sagemaker:ListTags"
   ]
  },
  "update": {
   "permissions": [
    "sagemaker:DescribeAlgorithm",
    "sagemaker:AddTags",
    "sagemaker:DeleteTags",
    "sagemaker:ListTags"
   ]
  }
 },
 "primaryIdentifier": [
  "/properties/AlgorithmArn"
 ],
 "properties": {
  "AlgorithmArn": {
   "description": "The Amazon Resource Name (ARN) of the algorithm.",
   "maxLength": 2048,
   "minLength": 1,
   "type": "string"
  },
  "AlgorithmDescription": {
   "description": "A description of the algorithm.",
   "maxLength": 1024,
   "minLength": 0,
   "pattern": "^[\\p{L}\\p{M}\\p{Z}\\p{S}\\p{N}\\p{P}]*$",
   "type": "string"
  },
  "AlgorithmName": {
   "description": "The name of the algorithm.",
   "maxLength": 63,
   "minLength": 1,
   "pattern": "^[a-zA-Z0-9](-*[a-zA-Z0-9]){0,62}$",
   "type": "string"
  },
  "CertifyForMarketplace": {
   "description": "Whether to certify the algorithm so that it can be listed in AWS Marketplace.",
   "type": "boolean"
  },
  "CreationTime": {
   "description": "A timestamp specifying when the algorithm was created.",
   "format": "date-time",
   "type": "string"
  },
  "InferenceSpecification": {
   "$ref": "#/definitions/InferenceSpecification"
  },
  "Tags": {
   "description": "An array of key-value pairs to apply to this resource.",
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "minItems": 0,
   "type": "array"
  },
  "TrainingSpecification": {
   "$ref": "#/definitions/TrainingSpecification"
  }
 },
 "readOnlyProperties": [
  "/properties/AlgorithmArn",
  "/properties/CreationTime"
 ],
 "required": [
  "AlgorithmName",
  "TrainingSpecification"
 ],
 "tagging": {
  "cloudFormationSystemTags": false,
  "permissions": [
   "sagemaker:AddTags",
   "sagemaker:DeleteTags",
   "sagemaker:ListTags"
  ],
  "tagOnCreate": true,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": true,
  "taggable": true
 },
 "typeName": "AWS::SageMaker::Algorithm"
}
