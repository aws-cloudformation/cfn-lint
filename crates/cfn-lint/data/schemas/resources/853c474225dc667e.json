{
 "additionalProperties": false,
 "definitions": {
  "ModelInvocationJobInputDataConfig": {
   "additionalProperties": false,
   "description": "Details about the location of the input to the batch inference job.",
   "properties": {
    "S3InputDataConfig": {
     "$ref": "#/definitions/ModelInvocationJobS3InputDataConfig"
    }
   },
   "required": [
    "S3InputDataConfig"
   ],
   "type": "object"
  },
  "ModelInvocationJobOutputDataConfig": {
   "additionalProperties": false,
   "description": "Details about the location of the output of the batch inference job.",
   "properties": {
    "S3OutputDataConfig": {
     "$ref": "#/definitions/ModelInvocationJobS3OutputDataConfig"
    }
   },
   "required": [
    "S3OutputDataConfig"
   ],
   "type": "object"
  },
  "ModelInvocationJobS3InputDataConfig": {
   "additionalProperties": false,
   "description": "Contains the configuration of the S3 location of the input data.",
   "properties": {
    "S3BucketOwner": {
     "description": "The ID of the AWS account that owns the S3 bucket containing the input data.",
     "pattern": "^[0-9]{12}$",
     "type": "string"
    },
    "S3Uri": {
     "description": "The S3 location of the input data.",
     "maxLength": 1024,
     "minLength": 1,
     "pattern": "^s3://[a-z0-9][-.a-z0-9]{1,61}[a-z0-9](?:/[-!_*'().a-z0-9A-Z]+(?:/[-!_*'().a-z0-9A-Z]+)*)?/?$",
     "type": "string"
    }
   },
   "required": [
    "S3Uri"
   ],
   "type": "object"
  },
  "ModelInvocationJobS3OutputDataConfig": {
   "additionalProperties": false,
   "description": "Contains the configuration of the S3 location of the output data.",
   "properties": {
    "S3BucketOwner": {
     "description": "The ID of the AWS account that owns the S3 bucket containing the output data.",
     "pattern": "^[0-9]{12}$",
     "type": "string"
    },
    "S3EncryptionKeyId": {
     "description": "The unique identifier of the key that encrypts the S3 location of the output data.",
     "maxLength": 2048,
     "minLength": 1,
     "pattern": "^(arn:aws(-[^:]+)?:kms:[a-zA-Z0-9-]*:[0-9]{12}:((key/[a-zA-Z0-9-]{36})|(alias/[a-zA-Z0-9-_/]+)))|([a-zA-Z0-9-]{36})|(alias/[a-zA-Z0-9-_/]+)$",
     "type": "string"
    },
    "S3Uri": {
     "description": "The S3 location of the output data.",
     "maxLength": 1024,
     "minLength": 1,
     "pattern": "^s3://[a-z0-9][-.a-z0-9]{1,61}[a-z0-9](?:/[-!_*'().a-z0-9A-Z]+(?:/[-!_*'().a-z0-9A-Z]+)*)?/?$",
     "type": "string"
    }
   },
   "required": [
    "S3Uri"
   ],
   "type": "object"
  },
  "ModelInvocationJobStatus": {
   "description": "The status of the batch inference job.",
   "enum": [
    "Submitted",
    "InProgress",
    "Completed",
    "Failed",
    "Stopping",
    "Stopped",
    "PartiallyCompleted",
    "Expired",
    "Validating",
    "Scheduled"
   ],
   "type": "string"
  },
  "Tag": {
   "additionalProperties": false,
   "description": "Definition of the key/value pair for a tag.",
   "properties": {
    "Key": {
     "description": "The key name of the tag.",
     "maxLength": 128,
     "minLength": 1,
     "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$",
     "type": "string"
    },
    "Value": {
     "description": "The value for the tag.",
     "maxLength": 256,
     "minLength": 0,
     "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$",
     "type": "string"
    }
   },
   "required": [
    "Key",
    "Value"
   ],
   "type": "object"
  },
  "VpcConfig": {
   "additionalProperties": false,
   "description": "The configuration of a virtual private cloud (VPC).",
   "properties": {
    "SecurityGroupIds": {
     "description": "An array of IDs for each security group in the VPC to use.",
     "format": "AWS::EC2::SecurityGroup.Ids",
     "insertionOrder": false,
     "items": {
      "format": "AWS::EC2::SecurityGroup.Id",
      "maxLength": 32,
      "pattern": "^[-0-9a-zA-Z]+$",
      "type": "string"
     },
     "maxItems": 5,
     "minItems": 1,
     "type": "array"
    },
    "SubnetIds": {
     "description": "An array of IDs for each subnet in the VPC to use.",
     "insertionOrder": false,
     "items": {
      "maxLength": 32,
      "pattern": "^[-0-9a-zA-Z]+$",
      "type": "string"
     },
     "maxItems": 16,
     "minItems": 1,
     "type": "array"
    }
   },
   "required": [
    "SubnetIds",
    "SecurityGroupIds"
   ],
   "type": "object"
  }
 },
 "description": "Resource Type definition for AWS::Bedrock::ModelInvocationJob",
 "handlers": {
  "list": {
   "permissions": [
    "bedrock:ListModelInvocationJobs"
   ]
  },
  "read": {
   "permissions": [
    "bedrock:GetModelInvocationJob",
    "bedrock:ListTagsForResource"
   ]
  }
 },
 "primaryIdentifier": [
  "/properties/JobArn"
 ],
 "properties": {
  "InputDataConfig": {
   "$ref": "#/definitions/ModelInvocationJobInputDataConfig",
   "description": "Details about the location of the input to the batch inference job."
  },
  "JobArn": {
   "description": "The Amazon Resource Name (ARN) of the batch inference job.",
   "maxLength": 1011,
   "pattern": "^(arn:aws(-[^:]+)?:bedrock:[a-z0-9-]{1,20}:[0-9]{12}:model-invocation-job/[a-z0-9]{12})$",
   "type": "string"
  },
  "JobExpirationTime": {
   "description": "The time at which the batch inference job times or timed out.",
   "format": "date-time",
   "type": "string"
  },
  "JobName": {
   "description": "A name to give the batch inference job.",
   "maxLength": 63,
   "minLength": 1,
   "pattern": "^[a-zA-Z0-9]{1,63}(-*[a-zA-Z0-9\\+\\-\\.]){0,63}$",
   "type": "string"
  },
  "LastModifiedTime": {
   "description": "The time at which the batch inference job was last modified.",
   "format": "date-time",
   "type": "string"
  },
  "ModelId": {
   "description": "The unique identifier of the foundation model to use for the batch inference job.",
   "maxLength": 2048,
   "minLength": 1,
   "pattern": "^(arn:aws(-[^:]+)?:bedrock:[a-z0-9-]{1,20}:(([0-9]{12}:custom-model/[a-z0-9-]{1,63}[.]{1}[a-z0-9-:]{1,63}/[a-z0-9]{12}$)|(:foundation-model/([a-z0-9-]{1,63}[.]{1}[a-z0-9-]{1,63}([.]?[a-z0-9-]{1,63})([:][a-z0-9-]{1,63}){0,2})|(([0-9a-zA-Z][_-]?)+)$)|([0-9]{12}:(inference-profile|application-inference-profile)/[a-zA-Z0-9-:.]+$)))|([a-z0-9-]{1,63}[.]{1}[a-z0-9-]{1,63}([.]?[a-z0-9-]{1,63})([:][a-z0-9-]{1,63}){0,2})|(([0-9a-zA-Z][_-]?)+)$",
   "type": "string"
  },
  "OutputDataConfig": {
   "$ref": "#/definitions/ModelInvocationJobOutputDataConfig",
   "description": "Details about the location of the output of the batch inference job."
  },
  "RoleArn": {
   "description": "The Amazon Resource Name (ARN) of the service role with permissions to carry out and manage batch inference.",
   "format": "AWS::IAM::Role.Arn",
   "maxLength": 2048,
   "pattern": "^arn:aws(-[^:]+)?:iam::([0-9]{12})?:role/.+$",
   "type": "string"
  },
  "Status": {
   "$ref": "#/definitions/ModelInvocationJobStatus"
  },
  "SubmitTime": {
   "description": "The time at which the batch inference job was submitted.",
   "format": "date-time",
   "type": "string"
  },
  "Tags": {
   "description": "Any tags associated with the batch inference job.",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 200,
   "minItems": 0,
   "type": "array"
  },
  "TimeoutDurationInHours": {
   "description": "The number of hours after which to force the batch inference job to time out.",
   "maximum": 168,
   "minimum": 24,
   "type": "integer"
  },
  "VpcConfig": {
   "$ref": "#/definitions/VpcConfig",
   "description": "The configuration of the Virtual Private Cloud (VPC) for the data in the batch inference job."
  }
 },
 "readOnlyProperties": [
  "/properties/JobArn",
  "/properties/JobName",
  "/properties/ModelId",
  "/properties/RoleArn",
  "/properties/InputDataConfig",
  "/properties/OutputDataConfig",
  "/properties/VpcConfig",
  "/properties/TimeoutDurationInHours",
  "/properties/Status",
  "/properties/SubmitTime",
  "/properties/LastModifiedTime",
  "/properties/JobExpirationTime",
  "/properties/Tags"
 ],
 "tagging": {
  "cloudFormationSystemTags": false,
  "permissions": [
   "bedrock:ListTagsForResource"
  ],
  "tagOnCreate": false,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": false,
  "taggable": true
 },
 "typeName": "AWS::Bedrock::ModelInvocationJob"
}
