   ],
   "type": "object"
  }
 },
 "description": "Resource schema for AWS::Chatbot::SlackChannelConfiguration.",
 "handlers": {
  "create": {
   "permissions": [
    "chatbot:CreateSlackChannelConfiguration",
    "chatbot:TagResource",
    "chatbot:AssociateToConfiguration",
