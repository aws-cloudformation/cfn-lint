   ]
  },
  "list": {
   "permissions": [
    "chatbot:DescribeSlackChannelConfigurations",
    "chatbot:ListAssociations"
   ]
  },
  "read": {
   "permissions": [
    "chatbot:DescribeSlackChannelConfigurations",
    "chatbot:ListAssociations"
   ]
  },
  "update": {
   "permissions": [
    "chatbot:UpdateSlackChannelConfiguration",
    "chatbot:TagResource",
    "chatbot:UntagResource",
