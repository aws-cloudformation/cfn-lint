     "$ref": "#/definitions/WorkloadIdentityArn"
    }
   },
   "required": [
    "WorkloadIdentityArn"
   ],
   "type": "object"
  }
 },
 "description": "Resource Type definition for AWS::BedrockAgentCore::Runtime",
