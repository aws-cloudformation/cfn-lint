{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/AgentRuntimeName"
 ],
 "definitions": {
  "AgentManagedRuntimeType": {
   "description": "Managed runtime types",
   "enum": [
    "PYTHON_3_10",
    "PYTHON_3_11",
    "PYTHON_3_12",
    "PYTHON_3_13",
    "PYTHON_3_14",
    "NODE_22"
   ],
   "type": "string"
  },
  "AgentRuntimeArn": {
   "maxLength": 2048,
   "pattern": "^arn:(aws(?:-cn|-us-gov|-iso(?:-[bef])?)?):bedrock-agentcore:[a-z0-9-]+:[0-9]{12}:runtime/[a-zA-Z][a-zA-Z0-9_]{0,99}-[a-zA-Z0-9]{10}$",
   "type": "string"
  },
  "AgentRuntimeArtifact": {
   "additionalProperties": false,
   "properties": {
    "CodeConfiguration": {
     "$ref": "#/definitions/CodeConfiguration"
    },
    "ContainerConfiguration": {
     "$ref": "#/definitions/ContainerConfiguration"
    }
   },
   "type": "object"
  },
  "AgentRuntimeId": {
   "pattern": "[a-zA-Z][a-zA-Z0-9_]{0,99}-[a-zA-Z0-9]{10}",
   "type": "string"
  },
  "AgentRuntimeName": {
   "pattern": "[a-zA-Z][a-zA-Z0-9_]{0,47}",
   "type": "string"
  },
  "AgentRuntimeVersion": {
   "maxLength": 5,
   "minLength": 1,
   "pattern": "([1-9][0-9]{0,4})",
   "type": "string"
  },
  "AgentStatus": {
   "enum": [
    "CREATING",
    "CREATE_FAILED",
    "UPDATING",
    "UPDATE_FAILED",
    "READY",
    "DELETING"
   ],
   "type": "string"
  },
  "AllowedAudience": {
   "description": "Allowed audience value",
   "type": "string"
  },
  "AllowedAudienceList": {
   "description": "List of allowed audiences",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/AllowedAudience"
   },
   "minItems": 1,
   "type": "array"
  },
  "AllowedClient": {
   "description": "Allowed client value",
   "type": "string"
  },
  "AllowedClientsList": {
   "description": "List of allowed clients",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/AllowedClient"
   },
   "minItems": 1,
   "type": "array"
  },
  "AllowedScope": {
   "description": "Allowed scope value",
   "pattern": "[\\x21\\x23-\\x5B\\x5D-\\x7E]+",
   "type": "string"
  },
  "AllowedScopesList": {
   "description": "List of allowed scopes",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/AllowedScope"
   },
   "minItems": 1,
   "type": "array"
  },
  "AllowedWorkloadConfiguration": {
   "additionalProperties": false,
   "description": "Allow-list of upstream workloads permitted to reach this resource via the workload identity chain. When set, the data plane enforces that the introspected workload chain's caller matches one of the configured hosting environments or workload identities; absent means no chain enforcement.",
   "properties": {
    "HostingEnvironments": {
     "$ref": "#/definitions/HostingEnvironmentsList"
    },
    "WorkloadIdentities": {
     "$ref": "#/definitions/WorkloadIdentitiesList"
    }
   },
   "type": "object"
  },
  "AuthorizerConfiguration": {
   "additionalProperties": false,
   "description": "Configuration for the authorizer",
   "properties": {
    "CustomJWTAuthorizer": {
     "$ref": "#/definitions/CustomJWTAuthorizerConfiguration"
    }
   },
   "type": "object"
  },
  "AuthorizingClaimMatchValueType": {
   "additionalProperties": false,
   "description": "The value or values in the custom claim to match and relationship of match",
   "properties": {
    "ClaimMatchOperator": {
     "$ref": "#/definitions/ClaimMatchOperator"
    },
    "ClaimMatchValue": {
     "$ref": "#/definitions/ClaimMatchValueType"
    }
   },
   "required": [
    "ClaimMatchOperator",
    "ClaimMatchValue"
   ],
   "type": "object"
  },
  "ClaimMatchOperator": {
   "description": "The relationship between the claim field value and the value or values being matched",
   "enum": [
    "EQUALS",
    "CONTAINS",
    "CONTAINS_ANY"
   ],
   "type": "string"
  },
  "ClaimMatchValueType": {
   "additionalProperties": false,
   "description": "The value or values in the custom claim to match for",
   "properties": {
    "MatchValueString": {
     "$ref": "#/definitions/MatchValueString"
    },
    "MatchValueStringList": {
     "$ref": "#/definitions/MatchValueStringList"
    }
   },
   "type": "object"
  },
  "ClientToken": {
   "maxLength": 256,
   "minLength": 33,
   "pattern": "^[a-zA-Z0-9-_]+$",
   "type": "string"
  },
  "Code": {
   "additionalProperties": false,
   "description": "Object represents source code from zip file",
   "properties": {
    "S3": {
     "$ref": "#/definitions/S3Location"
    }
   },
   "type": "object"
  },
  "CodeConfiguration": {
   "additionalProperties": false,
   "description": "Representation of a code configuration",
   "properties": {
    "Code": {
     "$ref": "#/definitions/Code"
    },
    "EntryPoint": {
     "$ref": "#/definitions/EntryPoints"
    },
    "Runtime": {
     "$ref": "#/definitions/AgentManagedRuntimeType"
    }
   },
   "required": [
    "Code",
    "Runtime",
    "EntryPoint"
   ],
   "type": "object"
  },
  "ContainerConfiguration": {
   "additionalProperties": false,
   "properties": {
    "ContainerUri": {
     "$ref": "#/definitions/RuntimeContainerUri"
    }
   },
   "required": [
    "ContainerUri"
   ],
   "type": "object"
  },
  "CreatedAt": {
   "type": "string"
  },
  "CustomClaimValidationType": {
   "additionalProperties": false,
   "description": "Required custom claim",
   "properties": {
    "AuthorizingClaimMatchValue": {
     "$ref": "#/definitions/AuthorizingClaimMatchValueType"
    },
    "InboundTokenClaimName": {
     "$ref": "#/definitions/InboundTokenClaimName"
    },
    "InboundTokenClaimValueType": {
     "$ref": "#/definitions/InboundTokenClaimValueType"
    }
   },
   "required": [
    "AuthorizingClaimMatchValue",
    "InboundTokenClaimName",
    "InboundTokenClaimValueType"
   ],
   "type": "object"
  },
  "CustomClaimsList": {
   "description": "List of required custom claims",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/CustomClaimValidationType"
   },
   "minItems": 1,
   "type": "array"
  },
  "CustomJWTAuthorizerConfiguration": {
   "additionalProperties": false,
   "description": "Configuration for custom JWT authorizer",
   "properties": {
    "AllowedAudience": {
     "$ref": "#/definitions/AllowedAudienceList"
    },
    "AllowedClients": {
     "$ref": "#/definitions/AllowedClientsList"
    },
    "AllowedScopes": {
     "$ref": "#/definitions/AllowedScopesList"
    },
    "AllowedWorkloadConfiguration": {
     "$ref": "#/definitions/AllowedWorkloadConfiguration"
    },
    "CustomClaims": {
     "$ref": "#/definitions/CustomClaimsList"
    },
    "DiscoveryUrl": {
     "$ref": "#/definitions/DiscoveryUrl"
    },
    "PrivateEndpoint": {
     "$ref": "#/definitions/PrivateEndpoint"
    },
    "PrivateEndpointOverrides": {
     "$ref": "#/definitions/PrivateEndpointOverridesList"
    }
   },
   "required": [
    "DiscoveryUrl"
   ],
   "type": "object"
  },
  "Description": {
   "maxLength": 1200,
   "minLength": 1,
   "type": "string"
  },
  "DiscoveryUrl": {
   "description": "OpenID Connect discovery URL",
   "pattern": "^.+/\\.well-known/openid-configuration$",
   "type": "string"
  },
  "EfsAccessPointArn": {
   "description": "ARN of the EFS access point",
   "maxLength": 128,
   "pattern": "^arn:aws[-a-z]*:elasticfilesystem:[0-9a-z-:]+:access-point/fsap-[0-9a-f]{8,40}$",
   "type": "string"
  },
  "EfsAccessPointConfiguration": {
   "additionalProperties": false,
   "description": "Configuration for EFS access point filesystem",
   "properties": {
    "AccessPointArn": {
     "$ref": "#/definitions/EfsAccessPointArn"
    },
    "MountPath": {
     "$ref": "#/definitions/MountPath"
    }
   },
   "required": [
    "AccessPointArn",
    "MountPath"
   ],
   "type": "object"
  },
  "EntryPoints": {
   "description": "List of entry points",
   "insertionOrder": true,
   "items": {
    "description": "Entry point",
    "type": "string"
   },
   "maxItems": 2,
   "minItems": 1,
   "type": "array"
  },
  "EnvironmentVariableKey": {
   "description": "Environment variable key",
   "maxLength": 128,
   "minLength": 1,
   "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
   "type": "string"
  },
  "EnvironmentVariableValue": {
   "description": "Environment variable value",
   "maxLength": 2048,
   "type": "string"
  },
  "EnvironmentVariablesMap": {
   "additionalProperties": false,
   "description": "Environment variable attributes",
   "maxProperties": 50,
   "patternProperties": {
    "^[a-zA-Z_][a-zA-Z0-9_]*$": {
     "description": "Environment variable value",
     "maxLength": 2048,
     "type": "string"
    }
   },
   "type": "object"
  },
  "FilesystemConfiguration": {
   "additionalProperties": false,
   "description": "Filesystem configuration for the runtime",
   "properties": {
    "EfsAccessPoint": {
     "$ref": "#/definitions/EfsAccessPointConfiguration"
    },
    "S3FilesAccessPoint": {
     "$ref": "#/definitions/S3FilesAccessPointConfiguration"
    },
    "SessionStorage": {
     "$ref": "#/definitions/SessionStorageConfiguration"
    }
   },
   "type": "object"
  },
  "FilesystemConfigurations": {
   "description": "List of filesystem configurations",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/FilesystemConfiguration"
   },
   "maxItems": 5,
   "minItems": 0,
   "type": "array"
  },
  "HeaderName": {
   "description": "HTTP header name",
   "maxLength": 256,
   "minLength": 1,
   "pattern": "^[A-Za-z][A-Za-z0-9_-]{0,255}$",
   "type": "string"
  },
  "HostingEnvironment": {
   "additionalProperties": false,
   "description": "An upstream workload identified by the ARN of its hosting environment (for example a Gateway or Runtime ARN)",
   "properties": {
    "Arn": {
     "description": "The ARN of the bedrock-agentcore hosting environment",
     "maxLength": 1011,
     "minLength": 20,
     "type": "string"
    }
   },
   "required": [
    "Arn"
   ],
   "type": "object"
  },
  "HostingEnvironmentsList": {
   "description": "List of allow-listed hosting environments",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/HostingEnvironment"
   },
   "maxItems": 10,
   "minItems": 1,
   "type": "array",
   "uniqueItems": true
  },
  "InboundTokenClaimName": {
   "description": "The name of the custom claim to validate",
   "pattern": "[A-Za-z0-9_.-:]+",
   "type": "string"
  },
  "InboundTokenClaimValueType": {
   "description": "Token claim data type",
   "enum": [
    "STRING",
    "STRING_ARRAY"
   ],
   "type": "string"
  },
  "LastUpdatedAt": {
   "type": "string"
  },
  "LifecycleConfiguration": {
   "additionalProperties": false,
   "description": "Configuration for managing the lifecycle of runtime sessions and resources",
   "properties": {
    "IdleRuntimeSessionTimeout": {
     "description": "Timeout in seconds for idle runtime sessions",
     "maximum": 28800,
     "minimum": 60,
     "type": "integer"
    },
    "MaxLifetime": {
     "description": "Maximum lifetime in seconds for runtime sessions",
     "maximum": 28800,
     "minimum": 60,
     "type": "integer"
    }
   },
   "type": "object"
  },
  "ManagedVpcResource": {
   "additionalProperties": false,
   "description": "Managed VPC resource configuration",
   "properties": {
    "EndpointIpAddressType": {
     "description": "The IP address type for the endpoint",
     "enum": [
      "IPV4",
      "IPV6"
     ],
     "type": "string"
    },
    "RoutingDomain": {
     "description": "An intermediate domain to use as the resource configuration endpoint instead of the actual target domain",
     "type": "string"
    },
    "SecurityGroupIds": {
     "description": "The security group IDs",
     "insertionOrder": false,
     "items": {
      "type": "string"
     },
     "type": "array"
    },
    "SubnetIds": {
     "description": "The subnet IDs",
     "insertionOrder": false,
     "items": {
      "type": "string"
     },
     "minItems": 1,
     "type": "array"
    },
    "Tags": {
     "additionalProperties": false,
     "description": "Tags to apply to the managed VPC Lattice resource gateway",
     "patternProperties": {
      "^[\\s\\S]+$": {
       "type": "string"
      }
     },
     "type": "object"
    },
    "VpcIdentifier": {
     "description": "The VPC identifier",
     "type": "string"
    }
   },
   "required": [
    "VpcIdentifier",
    "SubnetIds",
    "EndpointIpAddressType"
   ],
   "type": "object"
  },
  "MatchValueString": {
   "description": "The string value to match for",
   "pattern": "[A-Za-z0-9_.-]+",
   "type": "string"
  },
  "MatchValueStringList": {
   "description": "The list of strings to check for a match",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/MatchValueString"
   },
   "maxItems": 255,
   "minItems": 1,
   "type": "array"
  },
  "MountPath": {
   "description": "Mount path for filesystem configuration",
   "maxLength": 200,
   "minLength": 6,
   "pattern": "^/mnt/[a-zA-Z0-9._-]+/?$",
   "type": "string"
  },
  "NetworkConfiguration": {
   "additionalProperties": false,
   "properties": {
    "NetworkMode": {
     "$ref": "#/definitions/NetworkMode"
    },
    "NetworkModeConfig": {
     "$ref": "#/definitions/VpcConfig"
    }
   },
   "required": [
    "NetworkMode"
   ],
   "type": "object"
  },
  "NetworkMode": {
   "description": "Network mode configuration type",
   "enum": [
    "PUBLIC",
    "VPC"
   ],
   "type": "string"
  },
  "PrivateEndpoint": {
   "description": "Private endpoint configuration. Exactly one of SelfManagedLatticeResource or ManagedVpcResource must be specified.",
   "oneOf": [
    {
     "additionalProperties": false,
     "properties": {
      "SelfManagedLatticeResource": {
       "$ref": "#/definitions/SelfManagedLatticeResource"
      }
     },
     "required": [
      "SelfManagedLatticeResource"
     ],
     "title": "SelfManagedLatticeResource",
     "type": "object"
    },
    {
     "additionalProperties": false,
     "properties": {
      "ManagedVpcResource": {
       "$ref": "#/definitions/ManagedVpcResource"
      }
     },
     "required": [
      "ManagedVpcResource"
     ],
     "title": "ManagedVpcResource",
     "type": "object"
    }
   ],
   "type": "object"
  },
  "PrivateEndpointOverride": {
   "additionalProperties": false,
   "description": "Override mapping of a domain to a private endpoint",
   "properties": {
    "Domain": {
     "description": "The domain to override",
     "maxLength": 253,
     "minLength": 1,
     "type": "string"
    },
    "PrivateEndpoint": {
     "$ref": "#/definitions/PrivateEndpoint"
    }
   },
   "required": [
    "Domain",
    "PrivateEndpoint"
   ],
   "type": "object"
  },
  "PrivateEndpointOverridesList": {
