    },
    "VersionId": {
     "description": "S3 object version ID",
     "maxLength": 1024,
     "minLength": 3,
     "type": "string"
    }
   },
   "required": [
    "Bucket",
    "Prefix"
   ],
   "type": "object"
  },
  "SecurityGroupId": {
   "description": "Security group id",
   "format": "AWS::EC2::SecurityGroup.Id",
   "pattern": "^sg-[0-9a-zA-Z]{8,17}$",
   "type": "string"
  },
  "SecurityGroups": {
   "description": "Security groups for VPC",
