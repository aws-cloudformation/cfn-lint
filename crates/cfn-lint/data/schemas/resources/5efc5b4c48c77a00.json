    "AccessPointArn",
    "MountPath"
   ],
   "type": "object"
  },
  "S3Location": {
   "additionalProperties": false,
   "description": "S3 Location Configuration",
   "properties": {
    "Bucket": {
     "description": "S3 bucket name",
     "pattern": "^[a-z0-9][a-z0-9.-]{1,61}[a-z0-9]$",
