  },
  "Subnets": {
   "description": "Subnets for VPC",
   "format": "AWS::EC2::Subnet.Ids",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/SubnetId"
   },
   "maxItems": 16,
   "minItems": 1,
   "type": "array"
  },
  "TagsMap": {
   "additionalProperties": false,
