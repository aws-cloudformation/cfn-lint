{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/AuthenticationMaterial",
  "/properties/AuthenticationMaterialType",
  "/properties/Role",
  "/properties/SerialNumber"
 ],
 "definitions": {
  "AuthMaterialType": {
   "description": "Represent the type of authentication material provided",
   "enum": [
    "WIFI_SETUP_QR_BAR_CODE",
    "ZWAVE_QR_BAR_CODE",
    "ZIGBEE_QR_BAR_CODE"
   ],
   "type": "string"
  },
  "CapabilityReport": {
   "additionalProperties": false,
   "description": "Report of all capabilities supported by the device.",
   "properties": {
    "Endpoints": {
     "description": "Endpoints used in Capability Report.",
     "insertionOrder": false,
     "items": {
      "$ref": "#/definitions/CapabilityReportEndpoint"
     },
     "maxItems": 50,
     "minItems": 0,
     "type": "array"
    },
    "NodeId": {
     "description": "Numeric identifier of the node.",
     "maxLength": 64,
     "minLength": 1,
     "pattern": "^[a-zA-Z0-9=_.,@\\+\\-/]+$",
     "type": "string"
    },
    "Version": {
     "description": "Version of Capability Report",
     "maxLength": 10,
     "minLength": 1,
     "pattern": "^1\\.0\\.0$",
     "type": "string"
    }
   },
   "required": [
    "Endpoints",
    "Version"
   ],
   "type": "object"
  },
  "CapabilityReportCapability": {
   "additionalProperties": false,
   "description": "Capability used in Capability Report.",
   "properties": {
    "Actions": {
     "description": "Capability actions used in Capability Report.",
     "insertionOrder": false,
     "items": {
      "description": "Name for the AWS capability action.",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[/a-zA-Z0-9\\._ ]+$",
      "type": "string"
     },
     "maxItems": 100,
     "minItems": 0,
     "type": "array"
    },
    "Events": {
     "description": "Capability events used in Capability Report.",
     "insertionOrder": false,
     "items": {
      "description": "Name for the AWS capability event.",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[/a-zA-Z0-9\\._ ]+$",
      "type": "string"
     },
     "maxItems": 100,
     "minItems": 0,
     "type": "array"
    },
    "Id": {
     "description": "Identifier of a SchemaVersion",
     "maxLength": 128,
     "minLength": 1,
     "pattern": "^[a-zA-Z0-9.\\/]+(@(\\d+\\.\\d+|\\$latest))?$",
     "type": "string"
    },
    "Name": {
     "description": "Name for the AWS capability.",
     "maxLength": 128,
     "minLength": 1,
     "pattern": "^[/a-zA-Z0-9\\._ ]+$",
     "type": "string"
    },
    "Properties": {
     "description": "Capability properties used in Capability Report.",
     "insertionOrder": false,
     "items": {
      "description": "Name for the AWS capability property.",
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[/a-zA-Z0-9\\._ ]+$",
      "type": "string"
     },
     "maxItems": 100,
     "minItems": 0,
     "type": "array"
    },
    "Version": {
     "description": "Version for the AWS capability.",
     "maxLength": 64,
     "minLength": 1,
     "pattern": "^(0|[1-9][0-9]*)$",
     "type": "string"
    }
   },
   "required": [
    "Actions",
    "Events",
    "Id",
    "Name",
    "Properties",
    "Version"
   ],
   "type": "object"
  },
  "CapabilityReportEndpoint": {
   "additionalProperties": false,
   "description": "Endpoint used in Capability Report.",
   "properties": {
    "Capabilities": {
     "description": "Capabilities used in Capability Report.",
     "insertionOrder": false,
     "items": {
      "$ref": "#/definitions/CapabilityReportCapability"
     },
     "maxItems": 50,
     "minItems": 0,
     "type": "array"
    },
    "DeviceTypes": {
     "description": "The type of device..",
     "insertionOrder": false,
     "items": {
      "description": "The type of device.",
      "maxLength": 256,
      "pattern": "^[a-zA-Z0-9=_. ,@\\+\\-/]+$",
      "type": "string"
     },
     "maxItems": 50,
     "minItems": 0,
     "type": "array"
    },
    "Id": {
     "description": "Numeric identifier of the endpoint",
     "maxLength": 64,
     "minLength": 1,
     "pattern": "^[0-9a-zA-Z]+$",
     "type": "string"
    }
   },
   "required": [
    "Capabilities",
    "DeviceTypes",
    "Id"
   ],
   "type": "object"
  },
  "HubNetworkMode": {
   "description": "Network Mode setting of Hub",
   "enum": [
    "STANDARD",
    "NETWORK_WIDE_EXCLUSION"
   ],
   "type": "string"
  },
  "MetaData": {
   "additionalProperties": false,
   "description": "Meta data associated with the managedThing",
   "maxProperties": 50,
   "minProperties": 1,
   "patternProperties": {
    "[a-zA-Z0-9_.,@/:#-]+": {
     "maxLength": 800,
     "pattern": "[a-zA-Z0-9_.,@/:#-]*",
     "type": "string"
    }
   },
   "type": "object"
  },
  "ProvisioningStatus": {
   "description": "Status of a managed thing",
   "enum": [
    "UNASSOCIATED",
    "PRE_ASSOCIATED",
    "DISCOVERED",
    "ACTIVATED",
    "DELETION_FAILED",
    "DELETE_IN_PROGRESS",
    "ISOLATED",
    "DELETED"
   ],
   "type": "string"
  },
  "Role": {
   "description": "Represent the role of a managed thing",
   "enum": [
    "CONTROLLER",
    "DEVICE"
   ],
   "type": "string"
  },
  "TagsMap": {
   "additionalProperties": false,
   "description": "Tags associated with the resource",
   "maxProperties": 50,
   "minProperties": 0,
   "patternProperties": {
    ".+": {
     "maxLength": 256,
     "minLength": 0,
     "type": "string"
    }
   },
   "type": "object"
  },
  "Unit": {
   "additionalProperties": false,
   "type": "object"
  },
  "WiFiSimpleSetupConfiguration": {
   "additionalProperties": false,
   "description": "The Wi-Fi Simple Setup configuration for the managed thing, which defines provisioning capabilities and timeout settings.",
   "properties": {
    "EnableAsProvisionee": {
     "description": "Indicates whether the device can act as a provisionee in Wi-Fi Simple Setup, allowing it to be configured by other devices.",
     "type": "boolean"
    },
    "EnableAsProvisioner": {
     "description": "Indicates whether the device can act as a provisioner in Wi-Fi Simple Setup, allowing it to configure other devices.",
     "type": "boolean"
    },
    "TimeoutInMinutes": {
     "maximum": 15,
     "minimum": 5,
     "type": "integer"
    }
   },
   "type": "object"
  }
 },
 "deprecatedProperties": [
  "/properties/ActivatedAt",
  "/properties/AdvertisedProductId",
  "/properties/ConnectorDeviceId",
