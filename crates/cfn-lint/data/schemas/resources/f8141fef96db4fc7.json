    "sagemaker:ListTags"
   ]
  }
 },
 "primaryIdentifier": [
  "/properties/Arn"
 ],
 "properties": {
  "ActionName": {
   "description": "The name of the action. Must be unique to your account in an AWS Region.",
   "maxLength": 120,
   "minLength": 1,
   "pattern": "^[a-zA-Z0-9](-*[a-zA-Z0-9]){0,119}$",
   "type": "string"
  },
  "ActionType": {
   "description": "The action type.",
   "maxLength": 256,
   "minLength": 0,
   "type": "string"
  },
  "Arn": {
   "description": "The Amazon Resource Name (ARN) of the action.",
   "maxLength": 256,
   "pattern": "^arn:aws[a-z\\-]*:sagemaker:[a-z0-9\\-]*:[0-9]{12}:action/",
   "type": "string"
  },
  "CreationTime": {
   "description": "When the action was created.",
   "format": "date-time",
   "type": "string"
  },
  "Description": {
   "description": "The description of the action.",
   "maxLength": 3072,
   "minLength": 0,
   "type": "string"
  },
  "LastModifiedTime": {
   "description": "When the action was last modified.",
   "format": "date-time",
   "type": "string"
  },
  "MetadataProperties": {
   "$ref": "#/definitions/MetadataProperties",
   "description": "Metadata properties of the tracking entity, trial, or trial component."
  },
  "Properties": {
   "additionalProperties": false,
   "description": "A list of properties to add to the action.",
   "maxProperties": 30,
   "patternProperties": {
    ".+": {
     "maxLength": 2500,
     "type": "string"
    }
   },
   "type": "object"
  },
  "Source": {
   "$ref": "#/definitions/ActionSource",
   "description": "The source type, ID, and URI."
  },
  "Status": {
   "description": "The status of the action.",
   "enum": [
    "Unknown",
    "InProgress",
    "Completed",
    "Failed",
    "Stopping",
    "Stopped"
   ],
   "type": "string"
  },
  "Tags": {
   "description": "A list of tags to apply to the action.",
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "minItems": 0,
   "type": "array"
  }
 },
 "readOnlyProperties": [
