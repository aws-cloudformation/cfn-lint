   },
   "type": "array"
  },
  "Status": {
   "$ref": "#/definitions/HarnessStatus",
   "description": "The current status of the harness."
  },
  "SystemPrompt": {
   "description": "The system prompt that defines the agent's behavior.",
   "items": {
    "$ref": "#/definitions/HarnessSystemContentBlock"
   },
   "type": "array"
  },
  "Tags": {
   "description": "Tags to apply to the harness resource.",
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "type": "array"
  },
  "TimeoutSeconds": {
   "description": "The maximum duration in seconds for the agent loop execution per invocation.",
   "type": "integer"
  },
  "Tools": {
   "description": "The tools available to the agent.",
   "items": {
    "$ref": "#/definitions/HarnessTool"
   },
   "type": "array"
  },
  "Truncation": {
   "$ref": "#/definitions/HarnessTruncationConfiguration",
   "description": "The truncation configuration for managing conversation context."
  },
  "UpdatedAt": {
   "description": "The timestamp when the harness was last updated.",
   "format": "date-time",
   "type": "string"
  },
  "Version": {
   "description": "The version of the harness. Incremented on every successful update.",
   "maxLength": 5,
   "minLength": 1,
   "pattern": "^([1-9][0-9]{0,4})$",
   "type": "string"
  }
 },
