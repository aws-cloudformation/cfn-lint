    "minLength": 1,
    "pattern": "^(\\*|@?[^/]+(/[^/]+)?)$",
    "type": "string"
   },
   "type": "array"
  },
  "Arn": {
   "description": "The Amazon Resource Name (ARN) of the harness.",
   "pattern": "^arn:([^:]+)?:bedrock-agentcore:[a-z0-9-]+:[0-9]{12}:harness/[a-zA-Z][a-zA-Z0-9_]{0,39}-[a-zA-Z0-9]{10}$",
   "type": "string"
  },
