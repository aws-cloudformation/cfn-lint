   "description": "The Amazon Resource Name (ARN) of the OAuth2 credential provider",
   "pattern": "^arn:(aws|aws-us-gov):bedrock-agentcore:[A-Za-z0-9-]{1,64}:[0-9]{12}:token-vault/[a-zA-Z0-9-.]+/oauth2credentialprovider/[a-zA-Z0-9-]+$",
   "type": "string"
  },
  "CredentialProviderVendor": {
   "description": "The vendor of the OAuth2 credential provider",
   "enum": [
    "GoogleOauth2",
    "GithubOauth2",
    "SlackOauth2",
    "SalesforceOauth2",
    "MicrosoftOauth2",
    "CustomOauth2",
    "AtlassianOauth2",
    "LinkedinOauth2",
    "XOauth2",
    "OktaOauth2",
    "OneLoginOauth2",
    "PingOneOauth2",
    "FacebookOauth2",
    "YandexOauth2",
    "RedditOauth2",
    "ZoomOauth2",
    "TwitchOauth2",
    "SpotifyOauth2",
    "DropboxOauth2",
    "NotionOauth2",
    "HubspotOauth2",
    "CyberArkOauth2",
    "FusionAuthOauth2",
    "Auth0Oauth2",
    "CognitoOauth2"
   ],
   "type": "string"
  },
  "LastUpdatedTime": {
   "description": "The timestamp when the credential provider was last updated",
   "format": "date-time",
   "type": "string"
  },
  "Name": {
   "description": "The name of the OAuth2 credential provider",
   "maxLength": 128,
   "minLength": 1,
   "pattern": "^[a-zA-Z0-9\\-_]+$",
   "type": "string"
  },
