  "RedshiftPropertiesInput": {
   "additionalProperties": false,
   "description": "Redshift Properties Input",
   "properties": {
    "Credentials": {
     "$ref": "#/definitions/RedshiftCredentials"
    },
    "DatabaseName": {
     "maxLength": 64,
     "minLength": 1,
     "pattern": "^[a-z0-9_-]+$",
