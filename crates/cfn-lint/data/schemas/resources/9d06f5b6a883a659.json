    "WorkerType": {
     "maxLength": 256,
     "pattern": "^[G|Z].*$",
     "type": "string"
    }
   },
   "type": "object"
  },
  "TokenUrlParametersMap": {
   "additionalProperties": false,
   "description": "The token URL parameters.",
   "patternProperties": {
    ".+": {
     "maxLength": 512,
     "minLength": 1,
     "type": "string"
    }
   },
   "type": "object"
  },
