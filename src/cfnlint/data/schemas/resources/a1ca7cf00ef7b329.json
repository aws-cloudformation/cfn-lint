{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/Name",
  "/properties/RunConfigurations"
 ],
 "definitions": {
  "RunConfigurations": {
   "additionalProperties": false,
   "properties": {
    "VpcConfig": {
     "$ref": "#/definitions/VpcConfig"
    }
   },
   "type": "object"
  },
  "TagMap": {
   "additionalProperties": false,
   "patternProperties": {
    ".+": {
     "maxLength": 256,
     "minLength": 0,
     "type": "string"
    }
   },
   "type": "object"
  },
  "VpcConfig": {
   "additionalProperties": false,
   "properties": {
    "SecurityGroupIds": {
     "format": "AWS::EC2::SecurityGroup.Ids",
     "items": {
      "format": "AWS::EC2::SecurityGroup.Id",
      "maxLength": 128,
      "minLength": 4,
      "pattern": "^sg-[0-9a-f]+$",
      "type": "string"
     },
     "maxItems": 5,
     "type": "array"
    },
    "SubnetIds": {
     "items": {
      "maxLength": 128,
      "minLength": 8,
      "pattern": "^subnet-[0-9a-f]+$",
      "type": "string"
     },
     "maxItems": 16,
     "type": "array"
    }
   },
   "type": "object"
  }
 },
 "primaryIdentifier": [
  "/properties/Name"
 ],
 "properties": {
  "Arn": {
   "maxLength": 190,
   "minLength": 1,
   "pattern": "^arn:.+$",
   "type": "string"
  },
  "CreationTime": {
   "format": "date-time",
   "type": "string"
  },
  "Description": {
   "maxLength": 256,
   "minLength": 1,
   "pattern": "^[\\p{L}||\\p{M}||\\p{Z}||\\p{S}||\\p{N}||\\p{P}]+$",
   "type": "string"
  },
  "Name": {
   "maxLength": 128,
   "minLength": 1,
   "pattern": "^[A-Za-z0-9][A-Za-z0-9\\-\\._]*$",
   "type": "string"
  },
  "RunConfigurations": {
   "$ref": "#/definitions/RunConfigurations"
  },
  "Status": {
   "enum": [
    "CREATING",
    "ACTIVE",
    "UPDATING",
    "DELETING",
    "DELETED",
    "FAILED"
   ],
   "type": "string"
  },
  "Tags": {
   "$ref": "#/definitions/TagMap"
  },
  "Uuid": {
   "maxLength": 128,
   "minLength": 1,
   "pattern": "^[\\p{L}||\\p{M}||\\p{Z}||\\p{S}||\\p{N}||\\p{P}]+$",
   "type": "string"
  }
 },
 "readOnlyProperties": [
  "/properties/Arn",
  "/properties/Uuid",
  "/properties/Status",
  "/properties/CreationTime"
 ],
 "required": [
  "Name",
  "RunConfigurations"
 ],
 "tagging": {
  "cloudFormationSystemTags": false,
  "tagOnCreate": true,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": false,
  "taggable": true
 },
 "typeName": "AWS::Omics::Configuration"
}
