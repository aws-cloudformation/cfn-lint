    }
   },
   "type": "object"
  },
  "CreatedAt": {
   "format": "date-time",
   "type": "string"
  },
  "CreatedBy": {
   "$ref": "#/definitions/VersionCreatedBySource"
  },
  "Description": {
   "maxLength": 500,
   "minLength": 1,
   "pattern": "^.+$",
   "type": "string"
  },
  "LineageMetadata": {
   "$ref": "#/definitions/VersionLineageMetadata"
  },
  "Tags": {
   "insertionOrder": false,
   "items": {
