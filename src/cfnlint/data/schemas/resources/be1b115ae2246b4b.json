{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/FirstName",
  "/properties/AuthenticationType",
  "/properties/MessageAction",
  "/properties/LastName",
  "/properties/UserName"
 ],
 "primaryIdentifier": [
  "/properties/Id"
 ],
 "properties": {
  "AuthenticationType": {
   "enum": [
    "API",
    "AWS_AD",
    "SAML",
    "USERPOOL"
   ],
   "type": "string"
  },
  "FirstName": {
   "maxLength": 2048,
   "minLength": 0,
   "pattern": "^[A-Za-z0-9_\\-\\s]+$",
   "type": "string"
  },
  "Id": {
   "type": "string"
  },
  "LastName": {
   "maxLength": 2048,
   "minLength": 0,
   "pattern": "^[A-Za-z0-9_\\-\\s]+$",
   "type": "string"
  },
  "MessageAction": {
   "enum": [
    "RESEND",
    "SUPPRESS"
   ],
   "type": "string"
  },
  "UserName": {
   "maxLength": 128,
   "minLength": 1,
   "pattern": "^[\\p{L}\\p{M}\\p{S}\\p{N}\\p{P}]+$",
   "type": "string"
  }
 },
 "readOnlyProperties": [
  "/properties/Id"
 ],
 "required": [
  "UserName",
  "AuthenticationType"
 ],
 "typeName": "AWS::AppStream::User"
}
