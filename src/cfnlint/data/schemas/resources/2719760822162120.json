{
 "additionalIdentifiers": [
  [
   "/properties/DatasetId"
  ]
 ],
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/DatasetName",
  "/properties/SchemaType",
  "/properties/KmsKeyArn",
  "/properties/Source"
 ],
 "definitions": {
  "DataSourceType": {
   "additionalProperties": false,
   "properties": {
    "InlineExamples": {
     "$ref": "#/definitions/InlineExamplesSource"
    },
    "S3Source": {
     "$ref": "#/definitions/S3Source"
    }
   },
   "type": "object"
  },
  "InlineExamplesSource": {
   "additionalProperties": false,
   "properties": {
    "Examples": {
     "items": {
      "type": "object"
     },
     "maxItems": 1000,
     "minItems": 1,
     "type": "array"
    }
   },
   "required": [
    "Examples"
   ],
   "type": "object"
  },
  "S3Source": {
   "additionalProperties": false,
   "properties": {
    "S3Uri": {
     "pattern": "^s3://[a-z0-9][a-z0-9.\\-]{1,61}[a-z0-9]/.{1,1024}$",
     "type": "string"
    }
   },
   "required": [
    "S3Uri"
   ],
   "type": "object"
  },
  "Tag": {
   "additionalProperties": false,
   "properties": {
    "Key": {
     "maxLength": 128,
     "minLength": 1,
     "type": "string"
    },
    "Value": {
     "maxLength": 256,
     "minLength": 0,
     "type": "string"
    }
   },
   "required": [
    "Key",
    "Value"
   ],
   "type": "object"
  }
 },
 "primaryIdentifier": [
  "/properties/DatasetArn"
 ],
 "properties": {
  "CreatedAt": {
   "format": "date-time",
   "type": "string"
  },
  "DatasetArn": {
   "pattern": "^arn:aws(-[a-z]+)*:bedrock-agentcore:[a-z0-9-]+:[0-9]{12}:dataset/[a-zA-Z0-9_-]{1,110}$",
   "type": "string"
  },
  "DatasetId": {
   "pattern": "^[a-zA-Z0-9_-]{1,110}$",
   "type": "string"
  },
  "DatasetName": {
   "pattern": "^[a-zA-Z][a-zA-Z0-9_]{0,47}$",
   "type": "string"
  },
  "Description": {
   "maxLength": 200,
   "type": "string"
  },
  "ExampleCount": {
   "type": "integer"
  },
  "KmsKeyArn": {
   "maxLength": 2048,
   "minLength": 1,
   "pattern": "^arn:aws(|-cn|-us-gov):kms:[a-zA-Z0-9-]*:[0-9]{12}:key/[a-zA-Z0-9-]{36}$",
   "type": "string"
  },
  "SchemaType": {
   "enum": [
    "AGENTCORE_EVALUATION_PREDEFINED_V1",
    "AGENTCORE_EVALUATION_SIMULATED_V1"
   ],
   "type": "string"
  },
  "Source": {
   "$ref": "#/definitions/DataSourceType"
  },
  "Status": {
   "enum": [
    "CREATING",
    "UPDATING",
    "DELETING",
    "ACTIVE",
    "CREATE_FAILED",
    "UPDATE_FAILED",
    "DELETE_FAILED"
   ],
   "type": "string"
  },
  "Tags": {
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "type": "array"
  },
  "UpdatedAt": {
   "format": "date-time",
   "type": "string"
  }
 },
 "readOnlyProperties": [
  "/properties/DatasetArn",
  "/properties/DatasetId",
  "/properties/Status",
  "/properties/ExampleCount",
  "/properties/CreatedAt",
  "/properties/UpdatedAt"
 ],
 "required": [
  "DatasetName",
  "SchemaType"
 ],
 "tagging": {
  "cloudFormationSystemTags": false,
  "tagOnCreate": true,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": true,
  "taggable": true
 },
 "typeName": "AWS::BedrockAgentCore::Dataset",
 "writeOnlyProperties": [
  "/properties/Source"
 ]
}
