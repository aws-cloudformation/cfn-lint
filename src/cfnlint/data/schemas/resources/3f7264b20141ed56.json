  "ApiKeyDetails": {
   "additionalProperties": false,
   "properties": {
    "ApiKeyHeader": {
     "pattern": "^[a-zA-Z0-9-]+$",
     "type": "string"
    },
    "ApiKeyName": {
     "pattern": "^[a-zA-Z0-9_\\s-]+$",
     "type": "string"
    },
    "ApiKeyValue": {
     "pattern": "^[a-zA-Z0-9+/=._-]+$",
     "type": "string"
    }
   },
   "required": [
    "ApiKeyName",
    "ApiKeyValue",
    "ApiKeyHeader"
   ],
   "type": "object"
  },
  "BearerTokenDetails": {
   "additionalProperties": false,
   "properties": {
    "AuthorizationHeader": {
     "default": "Authorization",
     "pattern": "^[a-zA-Z0-9-]+$",
     "type": "string"
    },
    "TokenName": {
     "pattern": "^[a-zA-Z0-9_\\s-]+$",
     "type": "string"
    },
    "TokenValue": {
     "pattern": "^[\\S]+$",
     "type": "string"
    }
   },
   "required": [
    "TokenName",
    "TokenValue"
   ],
   "type": "object"
  },
  "DynatraceAuthorizationConfig": {
