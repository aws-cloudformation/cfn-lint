    },
    "TargetUrl": {
     "pattern": "^https://[a-zA-Z0-9]([a-zA-Z0-9.-]*[a-zA-Z0-9])?(?::[0-9]{1,5})?/?$",
     "type": "string"
    },
    "TokenType": {
     "enum": [
      "personal",
      "group"
     ],
     "type": "string"
    },
    "TokenValue": {
     "pattern": "^glpat-[a-zA-Z0-9._-]+$",
     "type": "string"
    }
   },
   "required": [
    "TargetUrl",
    "TokenType",
    "TokenValue"
   ],
   "type": "object"
  },
