{
 "additionalIdentifiers": [
  [
   "/properties/Name"
  ],
  [
   "/properties/Arn"
  ]
 ],
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/Name",
  "/properties/Tags",
  "/properties/Type",
  "/properties/StandbyReplicas",
  "/properties/CollectionGroupName",
  "/properties/EncryptionConfig",
  "/properties/VectorOptions",
  "/properties/VectorOptions/ServerlessVectorAcceleration"
 ],
 "definitions": {
  "CollectionType": {
   "enum": [
    "SEARCH",
    "TIMESERIES",
    "VECTORSEARCH"
   ],
   "type": "string"
  },
  "EncryptionConfig": {
   "additionalProperties": false,
   "properties": {
    "AWSOwnedKey": {
     "type": "boolean"
    },
    "KmsKeyArn": {
     "format": "AWS::KMS::Key.Arn",
     "type": "string"
    }
   },
   "type": "object"
  },
  "FipsEndpoints": {
   "additionalProperties": false,
   "properties": {
    "CollectionEndpoint": {
     "type": "string"
    },
    "DashboardEndpoint": {
     "type": "string"
    }
   },
   "type": "object"
  },
  "ServerlessVectorAcceleration": {
   "enum": [
    "ENABLED",
    "DISABLED",
    "ALLOWED"
   ],
   "type": "string"
  },
  "StandbyReplicas": {
   "enum": [
    "ENABLED",
    "DISABLED"
   ],
   "type": "string"
  },
  "Tag": {
   "additionalProperties": false,
   "properties": {
    "Key": {
     "maxLength": 128,
     "minLength": 1,
     "type": "string"
    },
    "Value": {
     "maxLength": 256,
     "minLength": 0,
     "type": "string"
    }
   },
   "required": [
    "Key",
    "Value"
   ],
   "type": "object"
  },
  "VectorOptions": {
   "additionalProperties": false,
   "properties": {
    "ServerlessVectorAcceleration": {
     "$ref": "#/definitions/ServerlessVectorAcceleration"
    }
   },
   "type": "object"
  }
 },
 "primaryIdentifier": [
  "/properties/Id"
 ],
 "properties": {
  "Arn": {
   "type": "string"
  },
  "CollectionEndpoint": {
   "type": "string"
  },
  "CollectionGroupName": {
   "maxLength": 32,
   "minLength": 3,
   "pattern": "^[a-z][a-z0-9-]+$",
   "type": "string"
  },
  "DashboardEndpoint": {
   "type": "string"
  },
  "Description": {
   "maxLength": 1000,
   "type": "string"
  },
  "EncryptionConfig": {
   "$ref": "#/definitions/EncryptionConfig"
  },
  "FipsEndpoints": {
   "$ref": "#/definitions/FipsEndpoints"
  },
  "Id": {
   "maxLength": 40,
   "minLength": 3,
   "type": "string"
  },
  "KmsKeyArn": {
   "format": "AWS::KMS::Key.Arn",
   "type": "string"
  },
  "Name": {
   "maxLength": 32,
   "minLength": 3,
   "pattern": "^[a-z][a-z0-9-]{2,31}$",
   "type": "string"
  },
  "StandbyReplicas": {
   "$ref": "#/definitions/StandbyReplicas"
  },
  "Tags": {
   "insertionOrder": false,
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 50,
   "minItems": 0,
   "type": "array"
  },
  "Type": {
   "$ref": "#/definitions/CollectionType"
  },
  "VectorOptions": {
   "$ref": "#/definitions/VectorOptions"
  }
 },
 "readOnlyProperties": [
  "/properties/Id",
  "/properties/Arn",
  "/properties/CollectionEndpoint",
  "/properties/DashboardEndpoint",
  "/properties/FipsEndpoints",
  "/properties/KmsKeyArn"
 ],
 "required": [
  "Name"
 ],
 "tagging": {
  "cloudFormationSystemTags": true,
  "tagOnCreate": true,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": false,
  "taggable": true
 },
 "typeName": "AWS::OpenSearchServerless::Collection",
 "writeOnlyProperties": [
  "/properties/Tags",
  "/properties/EncryptionConfig"
 ]
}
