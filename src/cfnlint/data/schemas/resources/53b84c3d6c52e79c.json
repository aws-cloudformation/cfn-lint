{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/EncryptionConfiguration",
  "/properties/LibraryName"
 ],
 "definitions": {
  "DataAutomationLibraryStatus": {
   "enum": [
    "ACTIVE",
    "DELETING"
   ],
   "type": "string"
  },
  "EncryptionConfiguration": {
   "additionalProperties": false,
   "properties": {
    "KmsEncryptionContext": {
     "$ref": "#/definitions/KmsEncryptionContext"
    },
    "KmsKeyId": {
     "anyOf": [
      {
       "format": "AWS::KMS::Key.Arn"
      },
      {
       "format": "AWS::KMS::Key.Id"
      },
      {
       "format": "AWS::KMS::Alias.AliasName"
      }
     ],
     "maxLength": 2048,
     "minLength": 1,
     "pattern": "^[A-Za-z0-9][A-Za-z0-9:_/+=,@.-]+$",
     "type": "string"
    }
   },
   "required": [
    "KmsKeyId"
   ],
   "type": "object"
  },
  "EntityType": {
   "enum": [
    "VOCABULARY"
   ],
   "type": "string"
  },
  "EntityTypeInfo": {
   "additionalProperties": false,
   "properties": {
    "EntityMetadata": {
     "type": "string"
    },
    "EntityType": {
     "$ref": "#/definitions/EntityType"
    }
   },
   "required": [
    "EntityType"
   ],
   "type": "object"
  },
  "KmsEncryptionContext": {
   "additionalProperties": false,
   "minProperties": 1,
   "patternProperties": {
    "^.*\\S.*$": {
     "maxLength": 2000,
     "minLength": 1,
     "pattern": "^.*\\S.*$",
     "type": "string"
    }
   },
   "type": "object"
  },
  "Tag": {
   "additionalProperties": false,
   "properties": {
    "Key": {
     "maxLength": 128,
     "minLength": 1,
     "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$",
     "type": "string"
    },
    "Value": {
     "maxLength": 256,
     "minLength": 0,
     "pattern": "^[a-zA-Z0-9\\s._:/=+@-]*$",
     "type": "string"
    }
   },
   "required": [
    "Key",
    "Value"
   ],
   "type": "object"
  }
 },
 "primaryIdentifier": [
  "/properties/LibraryArn"
 ],
 "properties": {
  "CreationTime": {
   "format": "date-time",
   "type": "string"
  },
  "EncryptionConfiguration": {
   "$ref": "#/definitions/EncryptionConfiguration"
  },
  "EntityTypes": {
   "items": {
    "$ref": "#/definitions/EntityTypeInfo"
   },
   "type": "array"
  },
  "LibraryArn": {
   "maxLength": 128,
   "pattern": "^arn:aws(|-cn|-iso|-iso-[a-z]|-us-gov):bedrock:[a-zA-Z0-9-]*:[0-9]{12}:data-automation-library/[a-zA-Z0-9-]{12,36}$",
   "type": "string"
  },
  "LibraryDescription": {
   "maxLength": 300,
   "minLength": 0,
   "type": "string"
  },
  "LibraryName": {
   "maxLength": 128,
   "minLength": 1,
   "pattern": "^[a-zA-Z0-9-_]+$",
   "type": "string"
  },
  "Status": {
   "$ref": "#/definitions/DataAutomationLibraryStatus"
  },
  "Tags": {
   "items": {
    "$ref": "#/definitions/Tag"
   },
   "maxItems": 200,
   "minItems": 0,
   "type": "array"
  }
 },
 "readOnlyProperties": [
  "/properties/CreationTime",
  "/properties/EntityTypes",
  "/properties/LibraryArn",
  "/properties/Status"
 ],
 "required": [
  "LibraryName"
 ],
 "tagging": {
  "cloudFormationSystemTags": false,
  "tagOnCreate": true,
  "tagProperty": "/properties/Tags",
  "tagUpdatable": true,
  "taggable": true
 },
 "typeName": "AWS::Bedrock::DataAutomationLibrary"
}
