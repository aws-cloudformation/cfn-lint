{
 "additionalProperties": false,
 "createOnlyProperties": [
  "/properties/ServiceArn"
 ],
 "primaryIdentifier": [
  "/properties/ServiceArn",
  "/properties/ServiceFunctionId"
 ],
 "properties": {
  "CreatedAt": {
   "format": "date-time",
   "type": "string"
  },
  "Criticality": {
   "enum": [
    "PRIMARY",
    "SUPPLEMENTAL"
   ],
   "type": "string"
  },
  "Description": {
   "maxLength": 500,
   "type": "string"
  },
  "Name": {
   "pattern": "^[A-Za-z0-9][A-Za-z0-9_\\-]{1,59}$",
   "type": "string"
  },
  "ResourceCount": {
   "type": "integer"
  },
  "ServiceArn": {
   "pattern": "^arn:(aws|aws-cn|aws-iso|aws-iso-[a-z]{1}|aws-us-gov):[A-Za-z0-9][A-Za-z0-9_/.-]{0,62}:([a-z]{2}-((iso[a-z]{0,1}-)|(gov-)){0,1}[a-z]+-[0-9]):[0-9]{12}:[A-Za-z0-9/][A-Za-z0-9:_/+.-]{0,1023}$",
   "type": "string"
  },
  "ServiceFunctionId": {
   "type": "string"
  },
  "Source": {
   "enum": [
    "AI_GENERATED",
    "USER"
   ],
   "type": "string"
  },
  "UpdatedAt": {
   "format": "date-time",
   "type": "string"
  }
 },
 "readOnlyProperties": [
  "/properties/ServiceFunctionId",
  "/properties/ResourceCount",
  "/properties/Source",
  "/properties/CreatedAt",
  "/properties/UpdatedAt"
 ],
 "required": [
  "ServiceArn",
  "Name",
  "Criticality"
 ],
 "tagging": {
  "cloudFormationSystemTags": false,
  "tagOnCreate": false,
  "tagUpdatable": false,
  "taggable": false
 },
 "typeName": "AWS::ResilienceHubV2::ServiceFunction"
}
